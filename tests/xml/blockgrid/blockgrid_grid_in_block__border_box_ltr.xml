<test name="blockgrid_grid_in_block__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="ltr" width="200px">
      <div display="grid" direction="ltr">
        <div direction="ltr" width="50px" height="50px"/>
      </div>
      <div display="block" direction="ltr" width="50px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="70">
      <node x="0" y="0" width="200" height="50">
        <node x="0" y="0" width="50" height="50"/>
      </node>
      <node x="0" y="50" width="50" height="20"/>
    </node>
  </expectations>
</test>
