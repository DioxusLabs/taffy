<test name="blockgrid_margin_y_collapse_through_blocked_by_grid__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" width="50px">
      <div display="block" direction="rtl" height="10px" margin-bottom="10px"/>
      <div display="grid" direction="rtl" margin-top="10px" margin-bottom="10px"/>
      <div display="block" direction="rtl" height="10px" margin-top="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="40">
      <node x="0" y="0" width="50" height="10"/>
      <node x="0" y="20" width="50" height="0"/>
      <node x="0" y="30" width="50" height="10"/>
    </node>
  </expectations>
</test>
