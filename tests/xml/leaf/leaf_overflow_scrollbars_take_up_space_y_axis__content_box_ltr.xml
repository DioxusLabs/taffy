<test name="leaf_overflow_scrollbars_take_up_space_y_axis__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <text box-sizing="content-box" direction="ltr" overflow-y="scroll" scrollbar-width="15">
      HH
    </text>
  </input>
  <expectations>
    <node x="0" y="0" width="35" height="10" scroll_width="0" scroll_height="0"/>
  </expectations>
</test>
