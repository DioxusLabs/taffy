<test name="leaf_overflow_scrollbars_overridden_by_max_size__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" overflow-x="scroll" overflow-y="scroll" scrollbar-width="15" max-width="2px" max-height="4px"/>
  </input>
  <expectations>
    <node x="0" y="0" width="2" height="4" scroll_width="0" scroll_height="0"/>
  </expectations>
</test>
