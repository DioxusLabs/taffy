<test name="gridflex_column_integration__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column">
      <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="1fr 1fr" grid-template-columns="1fr 1fr">
        <text box-sizing="content-box" direction="rtl">
          HH
        </text>
        <text box-sizing="content-box" direction="rtl">
          HH
        </text>
        <text box-sizing="content-box" direction="rtl">
          HH
        </text>
        <text box-sizing="content-box" direction="rtl">
          HH
        </text>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="40" height="20">
      <node x="0" y="0" width="40" height="20">
        <node x="20" y="0" width="20" height="10"/>
        <node x="0" y="0" width="20" height="10"/>
        <node x="20" y="10" width="20" height="10"/>
        <node x="0" y="10" width="20" height="10"/>
      </node>
    </node>
  </expectations>
</test>
