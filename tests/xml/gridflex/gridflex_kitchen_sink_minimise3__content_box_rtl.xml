<test name="gridflex_kitchen_sink_minimise3__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="50px">
      <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="30% 10%" grid-template-columns="auto 10%">
        <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
        <div box-sizing="content-box" direction="rtl"/>
        <div box-sizing="content-box" direction="rtl"/>
        <div box-sizing="content-box" direction="rtl"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="20">
      <node x="30" y="0" width="20" height="20">
        <node x="0" y="0" width="20" height="20"/>
        <node x="-2" y="0" width="2" height="6"/>
        <node x="0" y="6" width="20" height="2"/>
        <node x="-2" y="6" width="2" height="2"/>
      </node>
    </node>
  </expectations>
</test>
