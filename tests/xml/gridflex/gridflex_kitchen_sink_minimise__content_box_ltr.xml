<test name="gridflex_kitchen_sink_minimise__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr">
      <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="20px" grid-template-columns="1fr 1fr">
        <div box-sizing="content-box" direction="ltr" width="50px"/>
        <div box-sizing="content-box" direction="ltr"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="20">
      <node x="0" y="0" width="100" height="20">
        <node x="0" y="0" width="50" height="20"/>
        <node x="50" y="0" width="50" height="20"/>
      </node>
    </node>
  </expectations>
</test>
