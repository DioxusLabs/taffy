<test name="align_content_flex_start_with_flex__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" flex-wrap="wrap" align-content="flex-start" width="100px" height="120px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-shrink="0" flex-basis="0%" width="50px"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-shrink="0" flex-basis="0%" width="50px" height="10px"/>
      <div box-sizing="content-box" direction="ltr" width="50px"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%" width="50px"/>
      <div box-sizing="content-box" direction="ltr" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="120">
      <node x="0" y="0" width="50" height="40"/>
      <node x="0" y="40" width="50" height="40"/>
      <node x="0" y="80" width="50" height="0"/>
      <node x="0" y="80" width="50" height="40"/>
      <node x="0" y="120" width="50" height="0"/>
    </node>
  </expectations>
</test>
