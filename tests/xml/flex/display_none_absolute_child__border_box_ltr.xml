<test name="display_none_absolute_child__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div direction="ltr" flex-grow="1"/>
      <div display="none" direction="ltr" position="absolute" width="20px" height="20px" top="10px" left="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="100"/>
      <node x="0" y="0" width="0" height="0"/>
    </node>
  </expectations>
</test>
