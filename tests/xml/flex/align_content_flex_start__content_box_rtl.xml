<test name="align_content_flex_start__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap" align-content="flex-start" width="130px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="130" height="100">
      <node x="80" y="0" width="50" height="10"/>
      <node x="30" y="0" width="50" height="10"/>
      <node x="80" y="10" width="50" height="10"/>
      <node x="30" y="10" width="50" height="10"/>
      <node x="80" y="20" width="50" height="10"/>
    </node>
  </expectations>
</test>
