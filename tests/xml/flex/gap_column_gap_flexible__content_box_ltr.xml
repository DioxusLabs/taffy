  <input>
    <div box-sizing="content-box" direction="ltr" width="80px" height="100px" row-gap="20px" column-gap="10px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="80" height="100">
      <node x="0" y="0" width="20" height="100"/>
      <node x="30" y="0" width="20" height="100"/>
      <node x="60" y="0" width="20" height="100"/>
    </node>
  </expectations>
</test>
