<test name="flex_grow_within_constrained_max_width__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" width="200px" height="100px">
      <div box-sizing="content-box" direction="ltr" max-width="300px">
        <div box-sizing="content-box" direction="ltr" flex-grow="1" height="20px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="200" height="20">
        <node x="0" y="0" width="200" height="20"/>
      </node>
    </node>
  </expectations>
</test>
