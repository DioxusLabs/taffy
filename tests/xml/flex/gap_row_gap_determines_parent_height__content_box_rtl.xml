<test name="gap_row_gap_determines_parent_height__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" align-items="stretch" width="100px" row-gap="10px">
      <div box-sizing="content-box" direction="rtl" height="10px"/>
      <div box-sizing="content-box" direction="rtl" height="20px"/>
      <div box-sizing="content-box" direction="rtl" height="30px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="80">
      <node x="0" y="0" width="100" height="10"/>
      <node x="0" y="20" width="100" height="20"/>
      <node x="0" y="50" width="100" height="30"/>
    </node>
  </expectations>
</test>
