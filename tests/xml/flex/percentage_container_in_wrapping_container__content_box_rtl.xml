<test name="percentage_container_in_wrapping_container__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" align-items="center" justify-content="center" width="200px" height="200px">
      <div box-sizing="content-box" direction="rtl" flex-direction="column">
        <div box-sizing="content-box" direction="rtl" justify-content="center" width="100%">
          <div box-sizing="content-box" direction="rtl" width="50px" height="50px"/>
          <div box-sizing="content-box" direction="rtl" width="50px" height="50px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="50" y="75" width="100" height="50">
        <node x="0" y="0" width="100" height="50">
          <node x="50" y="0" width="50" height="50"/>
          <node x="0" y="0" width="50" height="50"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
