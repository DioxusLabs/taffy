<test name="border_flex_child__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" width="100px" height="100px" border-top="10px" border-left="10px" border-bottom="10px" border-right="10px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" width="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="10" y="10" width="100" height="100"/>
    </node>
  </expectations>
</test>
