<test name="overflow_main_axis_shrink_scroll__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="50px" height="50px">
      <text direction="ltr" overflow-x="scroll" overflow-y="scroll" scrollbar-width="15">
        HHHHHHHHHH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50">
      <node x="0" y="0" width="50" height="50" scroll_width="65" scroll_height="0"/>
    </node>
  </expectations>
</test>
