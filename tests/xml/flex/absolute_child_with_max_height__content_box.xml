<test name="absolute_child_with_max_height__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" flex-direction="column" width="100px" height="200px">
      <div box-sizing="content-box" position="absolute" flex-direction="column" max-height="100px" bottom="20px">
        <div box-sizing="content-box" width="100px" height="30px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="200">
      <node x="0" y="150" width="100" height="30">
        <node x="0" y="0" width="100" height="30"/>
      </node>
    </node>
  </expectations>
</test>
