<test name="wrap_row_align_items_center__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div flex-wrap="wrap" align-items="center" width="100px">
      <div width="30px" height="10px"/>
      <div width="30px" height="20px"/>
      <div width="30px" height="30px"/>
      <div width="30px" height="30px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="60">
      <node x="0" y="10" width="30" height="10"/>
      <node x="30" y="5" width="30" height="20"/>
      <node x="60" y="0" width="30" height="30"/>
      <node x="0" y="30" width="30" height="30"/>
    </node>
  </expectations>
</test>
