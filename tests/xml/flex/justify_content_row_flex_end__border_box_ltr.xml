<test name="justify_content_row_flex_end__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" justify-content="flex-end" width="100px" height="100px">
      <div direction="ltr" width="10px"/>
      <div direction="ltr" width="10px"/>
      <div direction="ltr" width="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="70" y="0" width="10" height="100"/>
      <node x="80" y="0" width="10" height="100"/>
      <node x="90" y="0" width="10" height="100"/>
    </node>
  </expectations>
</test>
