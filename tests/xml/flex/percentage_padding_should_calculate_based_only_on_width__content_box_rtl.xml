<test name="percentage_padding_should_calculate_based_only_on_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" width="200px" height="100px">
      <div box-sizing="content-box" direction="rtl" flex-direction="column" flex-grow="1" padding-top="10%" padding-left="10%" padding-bottom="10%" padding-right="10%">
        <div box-sizing="content-box" direction="rtl" width="10px" height="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="200" height="100">
        <node x="170" y="20" width="10" height="10"/>
      </node>
    </node>
  </expectations>
</test>
