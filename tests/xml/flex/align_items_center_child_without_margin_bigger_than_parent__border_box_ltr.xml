<test name="align_items_center_child_without_margin_bigger_than_parent__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" align-items="center" justify-content="center" width="50px" height="50px">
      <div direction="ltr" align-items="center">
        <div direction="ltr" width="70px" height="70px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50">
      <node x="-10" y="-10" width="70" height="70">
        <node x="0" y="0" width="70" height="70"/>
      </node>
    </node>
  </expectations>
</test>
