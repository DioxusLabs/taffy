<test name="absolute_minmax_top_left_bottom_right_max__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div direction="ltr" position="absolute" max-width="40px" max-height="30px" top="10px" left="10px" bottom="10px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="10" y="10" width="40" height="30"/>
    </node>
  </expectations>
</test>
