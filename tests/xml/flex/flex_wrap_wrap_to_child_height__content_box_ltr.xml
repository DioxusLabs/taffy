<test name="flex_wrap_wrap_to_child_height__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column">
      <div box-sizing="content-box" direction="ltr" flex-wrap="wrap" align-items="flex-start">
        <div box-sizing="content-box" direction="ltr" flex-direction="column" width="100px">
          <div box-sizing="content-box" direction="ltr" width="100px" height="100px"/>
        </div>
      </div>
      <div box-sizing="content-box" direction="ltr" width="100px" height="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="200">
      <node x="0" y="0" width="100" height="100">
        <node x="0" y="0" width="100" height="100">
          <node x="0" y="0" width="100" height="100"/>
        </node>
      </node>
      <node x="0" y="100" width="100" height="100"/>
    </node>
  </expectations>
</test>
