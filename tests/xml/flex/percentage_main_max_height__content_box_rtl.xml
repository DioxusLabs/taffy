    <div box-sizing="content-box" direction="rtl" flex-direction="column" width="71px">
      <div box-sizing="content-box" direction="rtl" flex-direction="column" align-items="flex-start" height="151px">
        <div box-sizing="content-box" direction="rtl" flex-basis="15px"/>
        <div box-sizing="content-box" direction="rtl" flex-basis="48px" max-height="33%"/>
