<test name="absolute_layout_align_items_and_justify_content_flex_end__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" align-items="flex-end" justify-content="flex-end" width="110px" height="100px">
      <div box-sizing="content-box" direction="rtl" position="absolute" width="60px" height="40px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="110" height="100">
      <node x="0" y="60" width="60" height="40"/>
    </node>
  </expectations>
</test>
