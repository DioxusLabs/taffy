<test name="child_min_max_width_flexing__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" align-items="stretch" width="120px" height="50px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-shrink="0" flex-basis="0px" min-width="60px"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-shrink="0" flex-basis="50%" max-width="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="50">
      <node x="0" y="0" width="100" height="50"/>
      <node x="100" y="0" width="20" height="50"/>
    </node>
  </expectations>
</test>
