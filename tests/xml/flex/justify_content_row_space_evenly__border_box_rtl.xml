<test name="justify_content_row_space_evenly__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" justify-content="space-evenly" width="100px" height="100px">
      <div direction="rtl" height="10px"/>
      <div direction="rtl" height="10px"/>
      <div direction="rtl" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="75" y="0" width="0" height="10"/>
      <node x="50" y="0" width="0" height="10"/>
      <node x="25" y="0" width="0" height="10"/>
    </node>
  </expectations>
</test>
