<test name="flex_basis_smaller_than_main_dimen_column__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" height="100px">
      <div direction="rtl" flex-basis="10px" width="50px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="100">
      <node x="0" y="0" width="50" height="10"/>
    </node>
  </expectations>
</test>
