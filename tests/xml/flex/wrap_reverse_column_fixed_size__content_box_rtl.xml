<test name="wrap_reverse_column_fixed_size__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" flex-wrap="wrap-reverse" align-items="center" width="200px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="30px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="30px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="40px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="35" y="0" width="30" height="10"/>
      <node x="35" y="10" width="30" height="20"/>
      <node x="35" y="30" width="30" height="30"/>
      <node x="35" y="60" width="30" height="40"/>
      <node x="135" y="0" width="30" height="50"/>
    </node>
  </expectations>
</test>
