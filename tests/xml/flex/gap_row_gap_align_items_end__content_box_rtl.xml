<test name="gap_row_gap_align_items_end__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap" align-items="flex-end" width="100px" height="200px" row-gap="20px" column-gap="10px">
      <div box-sizing="content-box" direction="rtl" width="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="200">
      <node x="80" y="90" width="20" height="0"/>
      <node x="50" y="90" width="20" height="0"/>
      <node x="20" y="90" width="20" height="0"/>
      <node x="80" y="200" width="20" height="0"/>
      <node x="50" y="200" width="20" height="0"/>
      <node x="20" y="200" width="20" height="0"/>
    </node>
  </expectations>
</test>
