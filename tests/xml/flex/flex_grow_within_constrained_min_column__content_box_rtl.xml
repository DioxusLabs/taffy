<test name="flex_grow_within_constrained_min_column__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" min-height="100px">
      <div box-sizing="content-box" direction="rtl" flex-grow="1"/>
      <div box-sizing="content-box" direction="rtl" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="0" height="100">
      <node x="0" y="0" width="0" height="50"/>
      <node x="0" y="50" width="0" height="50"/>
    </node>
  </expectations>
</test>
