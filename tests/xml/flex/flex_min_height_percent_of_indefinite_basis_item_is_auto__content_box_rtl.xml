<test name="flex_min_height_percent_of_indefinite_basis_item_is_auto__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" box-sizing="content-box" direction="rtl" flex-direction="column" width="200px" min-height="200px">
      <div display="block" box-sizing="content-box" direction="rtl" flex-grow="1">
        <div display="block" box-sizing="content-box" direction="rtl" min-height="100%"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="200" height="200">
        <node x="0" y="0" width="200" height="0"/>
      </node>
    </node>
  </expectations>
</test>
