<test name="percentage_size_of_flex_basis__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" width="100px">
      <div box-sizing="content-box" direction="ltr" flex-basis="50px">
        <div box-sizing="content-box" direction="ltr" width="100%" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="50" height="100">
        <node x="0" y="0" width="50" height="100"/>
      </node>
    </node>
  </expectations>
</test>
