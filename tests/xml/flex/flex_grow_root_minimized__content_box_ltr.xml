<test name="flex_grow_root_minimized__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" width="100px" min-height="100px" max-height="500px">
      <div box-sizing="content-box" direction="ltr" flex-direction="column" flex-grow="1" min-height="100px" max-height="500px">
        <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="200px"/>
        <div box-sizing="content-box" direction="ltr" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="300">
      <node x="0" y="0" width="100" height="300">
        <node x="0" y="0" width="100" height="200"/>
        <node x="0" y="200" width="100" height="100"/>
      </node>
    </node>
  </expectations>
</test>
