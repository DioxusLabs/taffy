<test name="margin_top__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" flex-direction="column" width="100px" height="100px">
      <div box-sizing="content-box" height="10px" margin-top="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="10" width="100" height="10"/>
    </node>
  </expectations>
</test>
