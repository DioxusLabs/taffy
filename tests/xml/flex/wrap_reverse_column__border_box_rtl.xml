<test name="wrap_reverse_column__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" flex-wrap="wrap-reverse" width="100px" height="100px">
      <div direction="rtl" width="30px" height="31px"/>
      <div direction="rtl" width="30px" height="32px"/>
      <div direction="rtl" width="30px" height="33px"/>
      <div direction="rtl" width="30px" height="34px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="30" height="31"/>
      <node x="0" y="31" width="30" height="32"/>
      <node x="0" y="63" width="30" height="33"/>
      <node x="50" y="0" width="30" height="34"/>
    </node>
  </expectations>
</test>
