<test name="margin_and_flex_column__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" width="100px" height="100px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" margin-top="10px" margin-bottom="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="10" width="100" height="80"/>
    </node>
  </expectations>
</test>
