<test name="justify_content_min_max__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" justify-content="center" width="100px" min-height="100px" max-height="200px">
      <div box-sizing="content-box" direction="rtl" width="60px" height="60px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="40" y="20" width="60" height="60"/>
    </node>
  </expectations>
</test>
