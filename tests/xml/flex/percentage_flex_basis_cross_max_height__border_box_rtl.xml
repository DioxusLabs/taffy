<test name="percentage_flex_basis_cross_max_height__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="200px" height="400px">
      <div direction="rtl" flex-grow="1" flex-basis="10%" max-height="60%"/>
      <div direction="rtl" flex-grow="4" flex-basis="10%" max-height="20%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="400">
      <node x="0" y="0" width="200" height="240"/>
      <node x="0" y="240" width="200" height="80"/>
    </node>
  </expectations>
</test>
