<test name="measure_remeasure_child_after_stretching__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <text box-sizing="content-box" direction="rtl">
        HH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="80" y="0" width="20" height="100"/>
    </node>
  </expectations>
</test>
