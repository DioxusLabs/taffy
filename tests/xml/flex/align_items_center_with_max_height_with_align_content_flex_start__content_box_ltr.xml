<test name="align_items_center_with_max_height_with_align_content_flex_start__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" align-items="center" align-content="flex-start" width="100px" max-height="100px">
      <div box-sizing="content-box" direction="ltr" width="10px" height="50px"/>
      <div box-sizing="content-box" direction="ltr" width="10px" height="150px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="25" width="10" height="50"/>
      <node x="10" y="-25" width="10" height="150"/>
    </node>
  </expectations>
</test>
