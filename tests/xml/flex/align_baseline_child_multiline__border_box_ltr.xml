<test name="align_baseline_child_multiline__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" align-items="baseline" width="100px">
      <div direction="ltr" width="50px" height="60px"/>
      <div direction="ltr" flex-wrap="wrap" width="50px">
        <div direction="ltr" width="25px" height="20px"/>
        <div direction="ltr" width="25px" height="10px"/>
        <div direction="ltr" width="25px" height="20px"/>
        <div direction="ltr" width="25px" height="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="80">
      <node x="0" y="0" width="50" height="60"/>
      <node x="50" y="40" width="50" height="40">
        <node x="0" y="0" width="25" height="20"/>
        <node x="25" y="0" width="25" height="10"/>
        <node x="0" y="20" width="25" height="20"/>
        <node x="25" y="20" width="25" height="10"/>
      </node>
    </node>
  </expectations>
</test>
