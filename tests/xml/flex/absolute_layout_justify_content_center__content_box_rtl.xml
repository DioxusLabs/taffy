<test name="absolute_layout_justify_content_center__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" justify-content="center" width="110px" height="100px">
      <div box-sizing="content-box" direction="rtl" position="absolute" width="60px" height="40px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="110" height="100">
      <node x="25" y="0" width="60" height="40"/>
    </node>
  </expectations>
</test>
