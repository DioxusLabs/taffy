<test name="border_stretch_child__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px" border-top="10px" border-left="10px" border-bottom="10px" border-right="10px">
      <div box-sizing="content-box" direction="rtl" width="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="100" y="10" width="10" height="100"/>
    </node>
  </expectations>
</test>
