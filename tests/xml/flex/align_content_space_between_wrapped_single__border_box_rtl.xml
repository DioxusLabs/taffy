<test name="align_content_space_between_wrapped_single__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-wrap="wrap" align-content="space-between" width="100px" height="100px">
      <div direction="rtl" width="50px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="10"/>
    </node>
  </expectations>
</test>
