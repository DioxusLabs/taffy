<test name="flex_wrap_align_stretch_fits_one_row__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" flex-wrap="wrap" width="150px" height="100px">
      <div direction="ltr" width="50px"/>
      <div direction="ltr" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="150" height="100">
      <node x="0" y="0" width="50" height="100"/>
      <node x="50" y="0" width="50" height="100"/>
    </node>
  </expectations>
</test>
