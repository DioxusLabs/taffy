<test name="absolute_child_with_main_margin__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="20px" height="37px">
      <div direction="ltr" position="absolute" width="9px" height="9px" margin-left="7px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="20" height="37">
      <node x="7" y="0" width="9" height="9"/>
    </node>
  </expectations>
</test>
