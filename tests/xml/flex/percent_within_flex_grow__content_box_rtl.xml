<test name="percent_within_flex_grow__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="350px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="100px"/>
      <div box-sizing="content-box" direction="rtl" flex-direction="column" flex-grow="1">
        <div box-sizing="content-box" direction="rtl" width="100%"/>
      </div>
      <div box-sizing="content-box" direction="rtl" width="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="350" height="100">
      <node x="250" y="0" width="100" height="100"/>
      <node x="100" y="0" width="150" height="100">
        <node x="0" y="0" width="150" height="0"/>
      </node>
      <node x="0" y="0" width="100" height="100"/>
    </node>
  </expectations>
</test>
