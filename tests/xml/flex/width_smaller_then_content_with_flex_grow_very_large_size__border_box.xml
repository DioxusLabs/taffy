<test name="width_smaller_then_content_with_flex_grow_very_large_size__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div width="200px">
      <div flex-direction="column" flex-grow="1" width="0px">
        <div width="70px" height="100px"/>
      </div>
      <div flex-direction="column" flex-grow="1" width="0px">
        <div width="20px" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="100" height="100">
        <node x="0" y="0" width="70" height="100"/>
      </node>
      <node x="100" y="0" width="100" height="100">
        <node x="0" y="0" width="20" height="100"/>
      </node>
    </node>
  </expectations>
</test>
