<test name="overflow_scrollbars_take_up_space_both_axis__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" overflow-x="scroll" overflow-y="scroll" scrollbar-width="15" width="50px" height="50px">
      <div direction="ltr" flex-grow="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50" scroll_width="0" scroll_height="0">
      <node x="0" y="0" width="35" height="35"/>
    </node>
  </expectations>
</test>
