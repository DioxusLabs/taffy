<test name="align_content_stretch_row_with_children__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" flex-wrap="wrap" align-content="stretch" width="150px" height="100px">
      <div box-sizing="content-box" flex-direction="column" width="50px">
        <div box-sizing="content-box" flex-grow="1" flex-basis="0%"/>
      </div>
      <div box-sizing="content-box" width="50px"/>
      <div box-sizing="content-box" width="50px"/>
      <div box-sizing="content-box" width="50px"/>
      <div box-sizing="content-box" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="150" height="100">
      <node x="0" y="0" width="50" height="50">
        <node x="0" y="0" width="50" height="50"/>
      </node>
      <node x="50" y="0" width="50" height="50"/>
      <node x="100" y="0" width="50" height="50"/>
      <node x="0" y="50" width="50" height="50"/>
      <node x="50" y="50" width="50" height="50"/>
    </node>
  </expectations>
</test>
