<test name="flex_grow_within_constrained_max_column__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div flex-direction="column" width="100px" max-height="100px">
      <div flex-basis="100px"/>
      <div height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="67"/>
      <node x="0" y="67" width="100" height="33"/>
    </node>
  </expectations>
</test>
