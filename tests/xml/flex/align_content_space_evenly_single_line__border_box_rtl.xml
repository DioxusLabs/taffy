<test name="align_content_space_evenly_single_line__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" align-content="space-evenly" width="100px" height="100px">
      <div direction="rtl" width="10px" height="10px"/>
      <div direction="rtl" width="10px" height="10px"/>
      <div direction="rtl" width="10px" height="10px"/>
      <div direction="rtl" width="10px" height="10px"/>
      <div direction="rtl" width="10px" height="10px"/>
      <div direction="rtl" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="90" y="0" width="10" height="10"/>
      <node x="80" y="0" width="10" height="10"/>
      <node x="70" y="0" width="10" height="10"/>
      <node x="60" y="0" width="10" height="10"/>
      <node x="50" y="0" width="10" height="10"/>
      <node x="40" y="0" width="10" height="10"/>
    </node>
  </expectations>
</test>
