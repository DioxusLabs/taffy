<test name="absolute_aspect_ratio_fill_height_from_inset__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" box-sizing="content-box" direction="rtl" width="400px" height="300px">
      <div box-sizing="content-box" direction="rtl" position="absolute" aspect-ratio="3" top="5%" left="10%" right="10%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="400" height="300">
      <node x="40" y="15" width="320" height="107"/>
    </node>
  </expectations>
</test>
