<test name="align_items_flex_start__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" align-items="flex-start" width="100px" height="100px">
      <div box-sizing="content-box" direction="ltr" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="10" height="10"/>
    </node>
  </expectations>
</test>
