<test name="width_smaller_then_content_with_flex_grow_large_size__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" width="100px">
      <div box-sizing="content-box" direction="ltr" flex-direction="column" flex-grow="1" width="0px">
        <div box-sizing="content-box" direction="ltr" width="70px" height="100px"/>
      </div>
      <div box-sizing="content-box" direction="ltr" flex-direction="column" flex-grow="1" width="0px">
        <div box-sizing="content-box" direction="ltr" width="20px" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="50" height="100">
        <node x="0" y="0" width="70" height="100"/>
      </node>
      <node x="50" y="0" width="50" height="100">
        <node x="0" y="0" width="20" height="100"/>
      </node>
    </node>
  </expectations>
</test>
