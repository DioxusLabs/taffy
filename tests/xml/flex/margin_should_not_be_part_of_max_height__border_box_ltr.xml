<test name="margin_should_not_be_part_of_max_height__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="250px" height="250px">
      <div direction="ltr" width="100px" height="100px" max-height="100px" margin-top="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="250" height="250">
      <node x="0" y="20" width="100" height="100"/>
    </node>
  </expectations>
</test>
