<test name="flex_grow_to_min__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" width="100px" min-height="100px" max-height="500px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1"/>
      <div box-sizing="content-box" direction="ltr" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="50"/>
      <node x="0" y="50" width="100" height="50"/>
    </node>
  </expectations>
</test>
