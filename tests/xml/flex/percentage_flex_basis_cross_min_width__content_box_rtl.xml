<test name="percentage_flex_basis_cross_min_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" width="200px" height="400px">
      <div box-sizing="content-box" direction="rtl" flex-grow="1" flex-basis="10%" min-width="60%"/>
      <div box-sizing="content-box" direction="rtl" flex-grow="4" flex-basis="15%" min-width="20%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="400">
      <node x="0" y="0" width="200" height="100"/>
      <node x="0" y="100" width="200" height="300"/>
    </node>
  </expectations>
</test>
