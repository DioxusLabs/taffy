<test name="padding_flex_child__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px" padding-top="10px" padding-left="10px" padding-bottom="10px" padding-right="10px">
      <div box-sizing="content-box" direction="rtl" flex-grow="1" width="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="10" y="10" width="100" height="100"/>
    </node>
  </expectations>
</test>
