<test name="margin_auto_top_and_bottom_stretch__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" align-items="stretch" width="200px" height="200px">
      <div box-sizing="content-box" direction="ltr" width="50px" height="50px" margin-top="auto" margin-bottom="auto"/>
      <div box-sizing="content-box" direction="ltr" width="50px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="50" width="50" height="50"/>
      <node x="0" y="150" width="50" height="50"/>
    </node>
  </expectations>
</test>
