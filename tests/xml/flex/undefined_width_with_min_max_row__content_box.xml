<test name="undefined_width_with_min_max_row__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" height="50px">
      <div box-sizing="content-box" min-width="60px" max-width="300px">
        <div box-sizing="content-box" width="30px" height="20px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="50">
      <node x="0" y="0" width="60" height="50">
        <node x="0" y="0" width="30" height="20"/>
      </node>
    </node>
  </expectations>
</test>
