  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" width="20px" height="10px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="5px"/>
      <text box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="5px">
        H
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="20" height="10">
      <node x="0" y="0" width="10" height="10"/>
      <node x="10" y="0" width="10" height="10"/>
    </node>
  </expectations>
</test>
