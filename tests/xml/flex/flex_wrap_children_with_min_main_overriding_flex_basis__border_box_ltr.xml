<test name="flex_wrap_children_with_min_main_overriding_flex_basis__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" flex-wrap="wrap" width="100px">
      <div direction="ltr" flex-basis="50px" height="50px" min-width="55px"/>
      <div direction="ltr" flex-basis="50px" height="50px" min-width="55px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="55" height="50"/>
      <node x="0" y="50" width="55" height="50"/>
    </node>
  </expectations>
</test>
