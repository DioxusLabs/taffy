<test name="display_none_with_position_absolute__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div display="none" box-sizing="content-box" direction="rtl" position="absolute" width="100px" height="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="0" height="0"/>
    </node>
  </expectations>
</test>
