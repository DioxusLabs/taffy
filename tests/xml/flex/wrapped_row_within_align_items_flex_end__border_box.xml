<test name="wrapped_row_within_align_items_flex_end__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div flex-direction="column" align-items="flex-end" width="200px" height="200px">
      <div flex-wrap="wrap">
        <div width="150px" height="80px"/>
        <div width="80px" height="80px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="200" height="160">
        <node x="0" y="0" width="150" height="80"/>
        <node x="0" y="80" width="80" height="80"/>
      </node>
    </node>
  </expectations>
</test>
