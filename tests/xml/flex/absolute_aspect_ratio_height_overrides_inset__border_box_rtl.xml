<test name="absolute_aspect_ratio_height_overrides_inset__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" direction="rtl" width="400px" height="300px">
      <div direction="rtl" position="absolute" height="10%" aspect-ratio="3" top="30%" bottom="50%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="400" height="300">
      <node x="310" y="90" width="90" height="30"/>
    </node>
  </expectations>
</test>
