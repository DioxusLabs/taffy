<test name="border_stretch_child__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" width="100px" height="100px" border-top="10px" border-left="10px" border-bottom="10px" border-right="10px">
      <div direction="rtl" width="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="80" y="10" width="10" height="80"/>
    </node>
  </expectations>
</test>
