<test name="gap_column_gap_wrap_align_center__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-wrap="wrap" align-content="center" width="100px" height="100px" row-gap="20px" column-gap="10px">
      <div direction="rtl" width="20px" height="20px"/>
      <div direction="rtl" width="20px" height="20px"/>
      <div direction="rtl" width="20px" height="20px"/>
      <div direction="rtl" width="20px" height="20px"/>
      <div direction="rtl" width="20px" height="20px"/>
      <div direction="rtl" width="20px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="80" y="20" width="20" height="20"/>
      <node x="50" y="20" width="20" height="20"/>
      <node x="20" y="20" width="20" height="20"/>
      <node x="80" y="60" width="20" height="20"/>
      <node x="50" y="60" width="20" height="20"/>
      <node x="20" y="60" width="20" height="20"/>
    </node>
  </expectations>
</test>
