<test name="justify_content_overflow_min_max__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" justify-content="center" min-height="100px" max-height="110px">
      <div direction="rtl" flex-shrink="0" width="50px" height="50px"/>
      <div direction="rtl" flex-shrink="0" width="50px" height="50px"/>
      <div direction="rtl" flex-shrink="0" width="50px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="110">
      <node x="0" y="-20" width="50" height="50"/>
      <node x="0" y="30" width="50" height="50"/>
      <node x="0" y="80" width="50" height="50"/>
    </node>
  </expectations>
</test>
