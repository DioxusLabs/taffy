    <div box-sizing="content-box" direction="ltr" width="80px" height="100px" column-gap="10px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%" margin-left="2px" margin-right="2px"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%" margin-left="10px" margin-right="10px"/>
      <div box-sizing="content-box" direction="ltr" flex-grow="1" flex-basis="0%" margin-left="15px" margin-right="15px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="80" height="100">
      <node x="2" y="0" width="2" height="100"/>
      <node x="26" y="0" width="2" height="100"/>
      <node x="63" y="0" width="2" height="100"/>
    </node>
