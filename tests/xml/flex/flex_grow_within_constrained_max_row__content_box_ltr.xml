<test name="flex_grow_within_constrained_max_row__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" width="200px">
      <div box-sizing="content-box" direction="ltr" height="100px" max-width="100px">
        <div box-sizing="content-box" direction="ltr" flex-basis="100px"/>
        <div box-sizing="content-box" direction="ltr" width="50px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="100" height="100">
        <node x="0" y="0" width="67" height="100"/>
        <node x="67" y="0" width="33" height="100"/>
      </node>
    </node>
  </expectations>
</test>
