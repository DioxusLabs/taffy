<test name="wrap_reverse_row_align_content_space_around__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" flex-wrap="wrap-reverse" align-content="space-around" width="100px">
      <div direction="ltr" width="30px" height="10px"/>
      <div direction="ltr" width="30px" height="20px"/>
      <div direction="ltr" width="30px" height="30px"/>
      <div direction="ltr" width="30px" height="40px"/>
      <div direction="ltr" width="30px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="80">
      <node x="0" y="70" width="30" height="10"/>
      <node x="30" y="60" width="30" height="20"/>
      <node x="60" y="50" width="30" height="30"/>
      <node x="0" y="10" width="30" height="40"/>
      <node x="30" y="0" width="30" height="50"/>
    </node>
  </expectations>
</test>
