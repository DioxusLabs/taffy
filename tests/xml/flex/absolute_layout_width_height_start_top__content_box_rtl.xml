<test name="absolute_layout_width_height_start_top__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" position="absolute" width="10px" height="10px" top="10px" left="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="10" y="10" width="10" height="10"/>
    </node>
  </expectations>
</test>
