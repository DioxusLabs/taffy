<test name="align_self_flex_end__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div direction="ltr" align-self="flex-end" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="90" width="10" height="10"/>
    </node>
  </expectations>
</test>
