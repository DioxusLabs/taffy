<test name="wrap_reverse_row__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-wrap="wrap-reverse" width="100px">
      <div box-sizing="content-box" direction="ltr" width="31px" height="30px"/>
      <div box-sizing="content-box" direction="ltr" width="32px" height="30px"/>
      <div box-sizing="content-box" direction="ltr" width="33px" height="30px"/>
      <div box-sizing="content-box" direction="ltr" width="34px" height="30px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="60">
      <node x="0" y="30" width="31" height="30"/>
      <node x="31" y="30" width="32" height="30"/>
      <node x="63" y="30" width="33" height="30"/>
      <node x="0" y="0" width="34" height="30"/>
    </node>
  </expectations>
</test>
