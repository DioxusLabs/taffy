<test name="child_with_padding_align_end__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" align-items="flex-end" justify-content="flex-end" width="200px" height="200px">
      <div direction="rtl" width="100px" height="100px" padding-top="20px" padding-left="20px" padding-bottom="20px" padding-right="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="100" width="100" height="100"/>
    </node>
  </expectations>
</test>
