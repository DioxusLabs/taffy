<test name="percentage_size_based_on_parent_inner_size__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="200px" height="400px" padding-top="20px" padding-left="20px" padding-bottom="20px" padding-right="20px">
      <div direction="rtl" width="50%" height="50%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="400">
      <node x="100" y="20" width="80" height="180"/>
    </node>
  </expectations>
</test>
