<test name="max_width_overrides_width__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box">
      <div box-sizing="content-box" width="200px" max-width="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="0">
      <node x="0" y="0" width="100" height="0"/>
    </node>
  </expectations>
</test>
