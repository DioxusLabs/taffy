<test name="aspect_ratio_flex_row_stretch_fill_height__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="40px" aspect-ratio="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="60" y="0" width="40" height="100"/>
    </node>
  </expectations>
</test>
