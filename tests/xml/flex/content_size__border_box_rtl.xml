    <div display="flex" direction="rtl" flex-direction="column" overflow-y="scroll" scrollbar-width="15" width="100px" height="100px">
      <div direction="rtl" height="30px">
        <text direction="rtl" position="absolute" flex-shrink="0" width="100%" height="20px" top="-10px">
          HHHH​HHHH
        </text>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100" scroll_width="0" scroll_height="0">
      <node x="15" y="0" width="85" height="30">
        <node x="0" y="-10" width="85" height="20"/>
      </node>
    </node>
  </expectations>
</test>
