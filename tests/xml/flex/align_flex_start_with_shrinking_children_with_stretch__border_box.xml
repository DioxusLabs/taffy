<test name="align_flex_start_with_shrinking_children_with_stretch__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div width="500px" height="500px">
      <div align-items="flex-start">
        <div align-items="stretch" flex-grow="1">
          <div flex-grow="1"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="500" height="500">
      <node x="0" y="0" width="0" height="500">
        <node x="0" y="0" width="0" height="0">
          <node x="0" y="0" width="0" height="0"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
