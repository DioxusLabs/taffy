<test name="flex_grow_in_at_most_container__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" align-items="flex-start" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl">
        <div box-sizing="content-box" direction="rtl" flex-grow="1" flex-basis="0px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="100" y="0" width="0" height="0">
        <node x="0" y="0" width="0" height="0"/>
      </node>
    </node>
  </expectations>
</test>
