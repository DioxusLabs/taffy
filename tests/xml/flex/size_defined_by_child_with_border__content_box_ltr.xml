<test name="size_defined_by_child_with_border__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" border-top="10px" border-left="10px" border-bottom="10px" border-right="10px">
      <div box-sizing="content-box" direction="ltr" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="30" height="30">
      <node x="10" y="10" width="10" height="10"/>
    </node>
  </expectations>
</test>
