    <div display="flex" flex-direction="column" width="320px" height="320px" border-top="60px" border-left="60px" border-bottom="60px" border-right="60px">
      <div display="flex" flex-wrap="wrap" align-content="space-around" justify-content="center" height="10px" row-gap="10px" column-gap="10px">
        <div flex-shrink="0" width="80%" height="20px"/>
        <div flex-shrink="0" width="80%" height="20px"/>
        <div flex-shrink="0" width="80%" height="20px"/>
