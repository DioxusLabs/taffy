<test name="flex_direction_column_direction_rtl__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="100px" height="100px">
      <div direction="ltr" width="10px"/>
      <div direction="ltr" width="10px"/>
      <div direction="ltr" width="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="90" y="0" width="10" height="0"/>
      <node x="90" y="0" width="10" height="0"/>
      <node x="90" y="0" width="10" height="0"/>
    </node>
  </expectations>
</test>
