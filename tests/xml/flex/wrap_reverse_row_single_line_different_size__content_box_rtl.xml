<test name="wrap_reverse_row_single_line_different_size__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap-reverse" align-content="flex-start" width="300px">
      <div box-sizing="content-box" direction="rtl" width="30px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="30px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="40px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="300" height="50">
      <node x="270" y="40" width="30" height="10"/>
      <node x="240" y="30" width="30" height="20"/>
      <node x="210" y="20" width="30" height="30"/>
      <node x="180" y="10" width="30" height="40"/>
      <node x="150" y="0" width="30" height="50"/>
    </node>
  </expectations>
</test>
