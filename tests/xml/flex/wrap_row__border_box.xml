<test name="wrap_row__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div flex-wrap="wrap" width="100px">
      <div width="31px" height="30px"/>
      <div width="32px" height="30px"/>
      <div width="33px" height="30px"/>
      <div width="34px" height="30px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="60">
      <node x="0" y="0" width="31" height="30"/>
      <node x="31" y="0" width="32" height="30"/>
      <node x="63" y="0" width="33" height="30"/>
      <node x="0" y="30" width="34" height="30"/>
    </node>
  </expectations>
</test>
