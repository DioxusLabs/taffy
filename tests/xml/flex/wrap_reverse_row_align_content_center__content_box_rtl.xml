<test name="wrap_reverse_row_align_content_center__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap-reverse" align-content="center" width="100px">
      <div box-sizing="content-box" direction="rtl" width="30px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="30px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="40px"/>
      <div box-sizing="content-box" direction="rtl" width="30px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="80">
      <node x="70" y="70" width="30" height="10"/>
      <node x="40" y="60" width="30" height="20"/>
      <node x="10" y="50" width="30" height="30"/>
      <node x="70" y="10" width="30" height="40"/>
      <node x="40" y="0" width="30" height="50"/>
    </node>
  </expectations>
</test>
