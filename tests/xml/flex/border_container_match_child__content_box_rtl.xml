<test name="border_container_match_child__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" border-top="10px" border-left="10px" border-bottom="10px" border-right="10px">
      <div box-sizing="content-box" direction="rtl" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="30" height="30">
      <node x="10" y="10" width="10" height="10"/>
    </node>
  </expectations>
</test>
