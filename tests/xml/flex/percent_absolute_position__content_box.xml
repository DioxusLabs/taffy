<test name="percent_absolute_position__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" flex-direction="column" width="60px" height="50px">
      <div box-sizing="content-box" position="absolute" width="100%" height="50px" left="50%">
        <div box-sizing="content-box" width="100%"/>
        <div box-sizing="content-box" width="100%"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="50">
      <node x="30" y="0" width="60" height="50">
        <node x="0" y="0" width="30" height="50"/>
        <node x="30" y="0" width="30" height="50"/>
      </node>
    </node>
  </expectations>
</test>
