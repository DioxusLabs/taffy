<test name="align_items_center_with_max_height_percentage_with_align_content_flex_start__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div display="flex" box-sizing="content-box" direction="rtl" align-items="center" align-content="flex-start" width="100px" height="100px" max-height="50%">
        <div box-sizing="content-box" direction="rtl" width="10px" height="10px"/>
        <div box-sizing="content-box" direction="rtl" width="10px" height="20px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="50">
        <node x="90" y="20" width="10" height="10"/>
        <node x="80" y="15" width="10" height="20"/>
      </node>
    </node>
  </expectations>
</test>
