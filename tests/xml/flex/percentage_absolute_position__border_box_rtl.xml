<test name="percentage_absolute_position__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="200px" height="100px">
      <div direction="rtl" position="absolute" width="10px" height="10px" top="10%" left="30%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="60" y="10" width="10" height="10"/>
    </node>
  </expectations>
</test>
