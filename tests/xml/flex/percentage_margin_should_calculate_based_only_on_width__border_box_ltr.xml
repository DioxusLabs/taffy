<test name="percentage_margin_should_calculate_based_only_on_width__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" flex-direction="column" width="200px" height="100px">
      <div direction="ltr" flex-direction="column" flex-grow="1" margin-top="10%" margin-left="10%" margin-bottom="10%" margin-right="10%">
        <div direction="ltr" width="10px" height="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="20" y="20" width="160" height="60">
        <node x="0" y="0" width="10" height="10"/>
      </node>
    </node>
  </expectations>
</test>
