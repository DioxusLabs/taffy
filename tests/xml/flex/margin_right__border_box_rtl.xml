<test name="margin_right__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" justify-content="flex-end" width="100px" height="100px">
      <div direction="rtl" width="10px" margin-right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="10" height="100"/>
    </node>
  </expectations>
</test>
