<test name="gap_column_gap_percentage_cyclic_partially_shrinkable__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" column-gap="50%">
      <div direction="rtl" flex-shrink="0" width="20px" height="40px"/>
      <div direction="rtl" width="20px" height="40px"/>
      <div direction="rtl" flex-shrink="0" width="20px" height="40px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="40">
      <node x="40" y="0" width="20" height="40"/>
      <node x="10" y="0" width="0" height="40"/>
      <node x="-40" y="0" width="20" height="40"/>
    </node>
  </expectations>
</test>
