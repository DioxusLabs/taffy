<test name="gap_column_gap_mixed_flexible__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" width="80px" height="100px" column-gap="10px">
      <div direction="rtl" width="20px"/>
      <div direction="rtl" flex-grow="1" flex-basis="0%"/>
      <div direction="rtl" width="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="80" height="100">
      <node x="60" y="0" width="20" height="100"/>
      <node x="30" y="0" width="20" height="100"/>
      <node x="0" y="0" width="20" height="100"/>
    </node>
  </expectations>
</test>
