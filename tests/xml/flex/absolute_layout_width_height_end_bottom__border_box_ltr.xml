<test name="absolute_layout_width_height_end_bottom__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div direction="ltr" position="absolute" width="10px" height="10px" bottom="10px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="80" y="80" width="10" height="10"/>
    </node>
  </expectations>
</test>
