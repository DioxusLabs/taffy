<test name="align_content_space_evenly_wrapped_single__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap" align-content="space-between" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="10"/>
    </node>
  </expectations>
</test>
