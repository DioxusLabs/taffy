<test name="flex_grow_within_constrained_min_row__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" height="100px" min-width="100px">
      <div direction="ltr" flex-grow="1"/>
      <div direction="ltr" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="50" height="100"/>
      <node x="50" y="0" width="50" height="100"/>
    </node>
  </expectations>
</test>
