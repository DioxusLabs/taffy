<test name="gap_column_gap_justify_space_between__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" justify-content="space-between" width="100px" height="100px" column-gap="10px">
      <div direction="rtl" width="20px"/>
      <div direction="rtl" width="20px"/>
      <div direction="rtl" width="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="80" y="0" width="20" height="100"/>
      <node x="40" y="0" width="20" height="100"/>
      <node x="0" y="0" width="20" height="100"/>
    </node>
  </expectations>
</test>
