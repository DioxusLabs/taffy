<test name="flex_grow_less_than_factor_one__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="500px" height="200px">
      <div box-sizing="content-box" direction="rtl" flex-grow="0.2" flex-shrink="0" flex-basis="40px"/>
      <div box-sizing="content-box" direction="rtl" flex-grow="0.2" flex-shrink="0"/>
      <div box-sizing="content-box" direction="rtl" flex-grow="0.4" flex-shrink="0"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="500" height="200">
      <node x="368" y="0" width="132" height="200"/>
      <node x="276" y="0" width="92" height="200"/>
      <node x="92" y="0" width="184" height="200"/>
    </node>
  </expectations>
</test>
