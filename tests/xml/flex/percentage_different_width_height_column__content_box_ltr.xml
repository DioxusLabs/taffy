<test name="percentage_different_width_height_column__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" width="200px" height="300px">
      <div box-sizing="content-box" direction="ltr" flex-grow="1"/>
      <div box-sizing="content-box" direction="ltr" height="30%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="300">
      <node x="0" y="0" width="200" height="210"/>
      <node x="0" y="210" width="200" height="90"/>
    </node>
  </expectations>
</test>
