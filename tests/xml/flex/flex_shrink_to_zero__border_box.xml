<test name="flex_shrink_to_zero__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div width="75px">
      <div flex-shrink="0" width="50px" height="50px"/>
      <div width="50px" height="50px"/>
      <div flex-shrink="0" width="50px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="75" height="50">
      <node x="0" y="0" width="50" height="50"/>
      <node x="50" y="0" width="0" height="50"/>
      <node x="50" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
