<test name="flex_root_ignored__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="100px" min-height="100px" max-height="500px">
      <div direction="rtl" flex-grow="1" flex-basis="200px"/>
      <div direction="rtl" height="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="300">
      <node x="0" y="0" width="100" height="200"/>
      <node x="0" y="200" width="100" height="100"/>
    </node>
  </expectations>
</test>
