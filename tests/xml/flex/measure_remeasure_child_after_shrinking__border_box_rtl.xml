<test name="measure_remeasure_child_after_shrinking__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" align-items="start" width="100px">
      <div direction="rtl" flex-shrink="0" width="50px" height="50px"/>
      <text direction="rtl">
        HH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="50">
      <node x="50" y="0" width="50" height="50"/>
      <node x="30" y="0" width="20" height="10"/>
    </node>
  </expectations>
</test>
