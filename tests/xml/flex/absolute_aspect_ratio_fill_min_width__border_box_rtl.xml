<test name="absolute_aspect_ratio_fill_min_width__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" direction="rtl" width="400px" height="300px">
      <div direction="rtl" position="absolute" min-height="50px" aspect-ratio="0.5"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="400" height="300">
      <node x="375" y="0" width="25" height="50"/>
    </node>
  </expectations>
</test>
