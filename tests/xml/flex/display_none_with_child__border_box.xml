<test name="display_none_with_child__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div width="100px" height="100px">
      <div flex-grow="1" flex-basis="0%"/>
      <div display="none" flex-direction="column" flex-grow="1" flex-basis="0%">
        <div flex-grow="1" flex-basis="0%" width="20px"/>
      </div>
      <div flex-grow="1" flex-basis="0%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="50" height="100"/>
      <node x="0" y="0" width="0" height="0">
        <node x="0" y="0" width="0" height="0"/>
      </node>
      <node x="50" y="0" width="50" height="100"/>
    </node>
  </expectations>
</test>
