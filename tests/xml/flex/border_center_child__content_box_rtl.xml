<test name="border_center_child__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" align-items="center" justify-content="center" width="100px" height="100px" border-top="10px" border-bottom="20px">
      <div box-sizing="content-box" direction="rtl" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="130">
      <node x="45" y="55" width="10" height="10"/>
    </node>
  </expectations>
</test>
