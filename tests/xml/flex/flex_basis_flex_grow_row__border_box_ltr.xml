<test name="flex_basis_flex_grow_row__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div direction="ltr" flex-grow="1" flex-basis="50px"/>
      <div direction="ltr" flex-grow="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="75" height="100"/>
      <node x="75" y="0" width="25" height="100"/>
    </node>
  </expectations>
</test>
