<test name="min_width_larger_than_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="25px" min-width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="0"/>
    </node>
  </expectations>
</test>
