<test name="flex_basis_smaller_then_content_with_flex_grow_small_size__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div width="10px">
      <div flex-direction="column" flex-grow="1" flex-basis="0px">
        <div width="70px" height="100px"/>
      </div>
      <div flex-direction="column" flex-grow="1" flex-basis="0px">
        <div width="20px" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="10" height="100">
      <node x="0" y="0" width="70" height="100">
        <node x="0" y="0" width="70" height="100"/>
      </node>
      <node x="70" y="0" width="20" height="100">
        <node x="0" y="0" width="20" height="100"/>
      </node>
    </node>
  </expectations>
</test>
