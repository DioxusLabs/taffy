<test name="rounding_flex_basis_flex_grow_row_width_of_100__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" flex-grow="1"/>
      <div box-sizing="content-box" direction="rtl" flex-grow="1"/>
      <div box-sizing="content-box" direction="rtl" flex-grow="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="67" y="0" width="33" height="100"/>
      <node x="33" y="0" width="34" height="100"/>
      <node x="0" y="0" width="33" height="100"/>
    </node>
  </expectations>
</test>
