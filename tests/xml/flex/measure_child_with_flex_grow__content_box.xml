<test name="measure_child_with_flex_grow__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" width="100px">
      <div box-sizing="content-box" width="50px" height="50px"/>
      <text box-sizing="content-box">
        H​H​H​H​H
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="50">
      <node x="0" y="0" width="50" height="50"/>
      <node x="50" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
