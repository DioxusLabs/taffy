<test name="flex_grow_height_maximized__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="100px" height="500px">
      <div direction="rtl" flex-direction="column" flex-grow="1" min-height="100px" max-height="500px">
        <div direction="rtl" flex-grow="1" flex-basis="200px"/>
        <div direction="rtl" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="500">
      <node x="0" y="0" width="100" height="500">
        <node x="0" y="0" width="100" height="400"/>
        <node x="0" y="400" width="100" height="100"/>
      </node>
    </node>
  </expectations>
</test>
