<test name="display_none_with_position__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" width="100px" height="100px">
      <div direction="rtl" flex-grow="1"/>
      <div display="none" direction="rtl" flex-grow="1" top="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="100"/>
      <node x="0" y="0" width="0" height="0"/>
    </node>
  </expectations>
</test>
