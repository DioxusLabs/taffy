<test name="align_items_center_with_child_top__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" align-items="center" width="100px" height="100px">
      <div direction="rtl" width="10px" height="10px" top="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="90" y="55" width="10" height="10"/>
    </node>
  </expectations>
</test>
