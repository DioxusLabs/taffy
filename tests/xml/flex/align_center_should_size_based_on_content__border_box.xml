<test name="align_center_should_size_based_on_content__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div align-items="center" width="100px" height="100px">
      <div justify-content="center">
        <div flex-grow="1">
          <div width="20px" height="20px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="40" width="20" height="20">
        <node x="0" y="0" width="20" height="20">
          <node x="0" y="0" width="20" height="20"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
