<test name="align_items_flex_end_child_with_margin_bigger_than_parent__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" align-items="center" justify-content="center" width="50px" height="50px">
      <div direction="rtl" align-items="flex-end">
        <div direction="rtl" width="50px" height="50px" margin-left="10px" margin-right="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50">
      <node x="-10" y="0" width="70" height="50">
        <node x="10" y="0" width="50" height="50"/>
      </node>
    </node>
  </expectations>
</test>
