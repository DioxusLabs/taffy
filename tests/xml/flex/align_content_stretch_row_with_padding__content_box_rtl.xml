<test name="align_content_stretch_row_with_padding__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap" align-content="stretch" width="150px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="50px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" padding-top="10px" padding-left="10px" padding-bottom="10px" padding-right="10px"/>
      <div box-sizing="content-box" direction="rtl" width="50px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" padding-top="10px" padding-left="10px" padding-bottom="10px" padding-right="10px"/>
      <div box-sizing="content-box" direction="rtl" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="150" height="100">
      <node x="100" y="0" width="50" height="40"/>
      <node x="30" y="0" width="70" height="40"/>
      <node x="100" y="40" width="50" height="40"/>
      <node x="30" y="40" width="70" height="40"/>
      <node x="100" y="80" width="50" height="20"/>
    </node>
  </expectations>
</test>
