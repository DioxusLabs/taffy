<test name="align_baseline_nested_column__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" align-items="baseline" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="50px" height="60px"/>
      <div box-sizing="content-box" direction="rtl" flex-direction="column">
        <div box-sizing="content-box" direction="rtl" flex-direction="column" width="50px" height="80px">
          <div box-sizing="content-box" direction="rtl" flex-direction="column" width="50px" height="30px"/>
          <div box-sizing="content-box" direction="rtl" flex-direction="column" width="50px" height="40px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="60"/>
      <node x="0" y="30" width="50" height="80">
        <node x="0" y="0" width="50" height="80">
          <node x="0" y="0" width="50" height="30"/>
          <node x="0" y="30" width="50" height="40"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
