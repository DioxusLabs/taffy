<test name="align_baseline_multiline_column2__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" flex-wrap="wrap" align-items="baseline" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" flex-direction="column" width="50px" height="50px"/>
      <div box-sizing="content-box" direction="rtl" flex-direction="column" width="30px" height="50px">
        <div box-sizing="content-box" direction="rtl" flex-direction="column" width="20px" height="20px"/>
      </div>
      <div box-sizing="content-box" direction="rtl" flex-direction="column" width="40px" height="70px">
        <div box-sizing="content-box" direction="rtl" flex-direction="column" width="10px" height="10px"/>
      </div>
      <div box-sizing="content-box" direction="rtl" flex-direction="column" width="50px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="50"/>
      <node x="50" y="50" width="30" height="50">
        <node x="10" y="0" width="20" height="20"/>
      </node>
      <node x="0" y="0" width="40" height="70">
        <node x="30" y="0" width="10" height="10"/>
      </node>
      <node x="0" y="70" width="50" height="20"/>
    </node>
  </expectations>
</test>
