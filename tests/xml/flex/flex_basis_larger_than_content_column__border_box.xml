<test name="flex_basis_larger_than_content_column__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div flex-direction="column" height="100px">
      <div flex-direction="column" flex-basis="50px">
        <div width="100px" height="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="50">
        <node x="0" y="0" width="100" height="10"/>
      </node>
    </node>
  </expectations>
</test>
