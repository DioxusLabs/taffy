<test name="wrap_row_align_items_flex_end__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-wrap="wrap" align-items="flex-end" width="100px">
      <div box-sizing="content-box" direction="ltr" width="30px" height="10px"/>
      <div box-sizing="content-box" direction="ltr" width="30px" height="20px"/>
      <div box-sizing="content-box" direction="ltr" width="30px" height="30px"/>
      <div box-sizing="content-box" direction="ltr" width="30px" height="30px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="60">
      <node x="0" y="20" width="30" height="10"/>
      <node x="30" y="10" width="30" height="20"/>
      <node x="60" y="0" width="30" height="30"/>
      <node x="0" y="30" width="30" height="30"/>
    </node>
  </expectations>
</test>
