<test name="flex_shrink_by_outer_margin_with_max_size__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" height="100px" max-height="80px">
      <div box-sizing="content-box" direction="ltr" width="20px" height="20px" margin-top="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="20" height="80">
      <node x="0" y="100" width="20" height="0"/>
    </node>
  </expectations>
</test>
