<test name="align_content_stretch_row_with_max_height__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-wrap="wrap" align-content="stretch" width="150px" height="100px">
      <div direction="rtl" width="50px"/>
      <div direction="rtl" width="50px" max-height="20px"/>
      <div direction="rtl" width="50px"/>
      <div direction="rtl" width="50px"/>
      <div direction="rtl" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="150" height="100">
      <node x="100" y="0" width="50" height="50"/>
      <node x="50" y="0" width="50" height="20"/>
      <node x="0" y="0" width="50" height="50"/>
      <node x="100" y="50" width="50" height="50"/>
      <node x="50" y="50" width="50" height="50"/>
    </node>
  </expectations>
</test>
