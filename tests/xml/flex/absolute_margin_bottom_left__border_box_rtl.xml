<test name="absolute_margin_bottom_left__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" justify-content="flex-end" width="100px" height="100px">
      <div direction="rtl" position="absolute" width="10px" height="10px" margin-left="10px" margin-bottom="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="90" y="80" width="10" height="10"/>
    </node>
  </expectations>
</test>
