<test name="align_content_stretch_row_wrap__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-wrap="wrap" align-content="stretch" width="150px" height="100px">
      <div direction="rtl" width="100px">
        <div direction="rtl" width="50px" height="150px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="150" height="100">
      <node x="50" y="0" width="100" height="150">
        <node x="50" y="0" width="50" height="150"/>
      </node>
    </node>
  </expectations>
</test>
