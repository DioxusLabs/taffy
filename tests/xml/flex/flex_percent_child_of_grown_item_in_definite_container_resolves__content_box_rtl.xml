<test name="flex_percent_child_of_grown_item_in_definite_container_resolves__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" box-sizing="content-box" direction="rtl" flex-direction="column" width="200px" height="200px">
      <div display="block" box-sizing="content-box" direction="rtl" flex-grow="1">
        <div display="block" box-sizing="content-box" direction="rtl" height="100%"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="200" height="200">
        <node x="0" y="0" width="200" height="200"/>
      </node>
    </node>
  </expectations>
</test>
