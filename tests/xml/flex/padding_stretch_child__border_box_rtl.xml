<test name="padding_stretch_child__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" width="100px" height="100px" padding-top="10px" padding-left="10px" padding-bottom="10px" padding-right="10px">
      <div direction="rtl" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="90" y="10" width="0" height="10"/>
    </node>
  </expectations>
</test>
