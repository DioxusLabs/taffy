    <div box-sizing="content-box" direction="rtl" flex-wrap="wrap" align-content="space-around" width="100px" height="100px" row-gap="20px" column-gap="10px">
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
