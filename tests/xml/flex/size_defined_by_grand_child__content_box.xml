<test name="size_defined_by_grand_child__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box">
      <div box-sizing="content-box">
        <div box-sizing="content-box" width="100px" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="100">
        <node x="0" y="0" width="100" height="100"/>
      </node>
    </node>
  </expectations>
</test>
