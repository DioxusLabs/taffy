  <input>
    <div direction="ltr" flex-direction="column" flex-wrap="wrap-reverse" width="100px" height="100px">
      <div direction="ltr" position="absolute" align-self="flex-end" width="20px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="20" height="20"/>
    </node>
  </expectations>
</test>
