<test name="gap_column_gap_justify_flex_end__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" justify-content="flex-end" width="100px" height="100px" column-gap="10px">
      <div direction="ltr" width="20px"/>
      <div direction="ltr" width="20px"/>
      <div direction="ltr" width="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="20" y="0" width="20" height="100"/>
      <node x="50" y="0" width="20" height="100"/>
      <node x="80" y="0" width="20" height="100"/>
    </node>
  </expectations>
</test>
