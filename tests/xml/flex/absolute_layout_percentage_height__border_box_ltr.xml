<test name="absolute_layout_percentage_height__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="200px" height="100px">
      <div direction="ltr" position="absolute" width="10px" height="50%" top="10px" left="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="10" y="10" width="10" height="50"/>
    </node>
  </expectations>
</test>
