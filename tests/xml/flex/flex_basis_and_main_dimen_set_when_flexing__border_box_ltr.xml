<test name="flex_basis_and_main_dimen_set_when_flexing__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px">
      <div direction="ltr" flex-grow="1" flex-basis="10px" width="50px" height="50px"/>
      <div direction="ltr" flex-grow="1" flex-basis="10px" width="0px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="50">
      <node x="0" y="0" width="50" height="50"/>
      <node x="50" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
