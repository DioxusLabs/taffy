<test name="flex_grow_to_min__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" width="100px" min-height="100px" max-height="500px">
      <div direction="rtl" flex-grow="1"/>
      <div direction="rtl" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="50"/>
      <node x="0" y="50" width="100" height="50"/>
    </node>
  </expectations>
</test>
