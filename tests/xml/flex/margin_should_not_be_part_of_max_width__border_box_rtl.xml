<test name="margin_should_not_be_part_of_max_width__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" width="250px" height="250px">
      <div direction="rtl" width="100px" height="100px" max-width="100px" margin-left="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="250" height="250">
      <node x="150" y="0" width="100" height="100"/>
    </node>
  </expectations>
</test>
