  <input>
    <div direction="ltr">
      <div direction="ltr" min-height="100px" max-height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="0" height="100">
      <node x="0" y="0" width="0" height="100"/>
    </node>
  </expectations>
</test>
