<test name="align_items_center_with_height_with_padding_border_with_wrap__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl">
      <div display="flex" direction="rtl" flex-wrap="wrap" align-items="center" align-content="flex-start" width="100px" height="100px">
        <div direction="rtl" width="10px" height="10px"/>
        <div direction="rtl" width="10px" height="20px"/>
      </div>
      <div display="flex" direction="rtl" flex-wrap="wrap" align-items="center" width="100px" height="100px">
        <div direction="rtl" width="10px" height="10px"/>
        <div direction="rtl" width="10px" height="20px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="100" y="0" width="100" height="100">
        <node x="90" y="5" width="10" height="10"/>
        <node x="80" y="0" width="10" height="20"/>
      </node>
      <node x="0" y="0" width="100" height="100">
        <node x="90" y="45" width="10" height="10"/>
        <node x="80" y="40" width="10" height="20"/>
      </node>
    </node>
  </expectations>
</test>
