<test name="align_content_end__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" flex-direction="column" flex-wrap="wrap" align-content="end" width="100px" height="100px">
      <div direction="rtl" width="50px" height="10px"/>
      <div direction="rtl" width="50px" height="10px"/>
      <div direction="rtl" width="50px" height="10px"/>
      <div direction="rtl" width="50px" height="10px"/>
      <div direction="rtl" width="50px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="50" height="10"/>
      <node x="0" y="10" width="50" height="10"/>
      <node x="0" y="20" width="50" height="10"/>
      <node x="0" y="30" width="50" height="10"/>
      <node x="0" y="40" width="50" height="10"/>
    </node>
  </expectations>
</test>
