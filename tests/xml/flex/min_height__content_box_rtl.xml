<test name="min_height__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" flex-direction="column" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" flex-grow="1" min-height="60px"/>
      <div box-sizing="content-box" direction="rtl" flex-grow="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="60"/>
      <node x="0" y="60" width="100" height="40"/>
    </node>
  </expectations>
</test>
