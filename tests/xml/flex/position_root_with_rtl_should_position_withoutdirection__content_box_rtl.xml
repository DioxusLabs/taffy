<test name="position_root_with_rtl_should_position_withoutdirection__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl">
      <div box-sizing="content-box" direction="rtl" width="52px" height="52px" left="72px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="52" height="52">
      <node x="72" y="0" width="52" height="52"/>
    </node>
  </expectations>
</test>
