<test name="padding_container_match_child__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" padding-top="10px" padding-left="10px" padding-bottom="10px" padding-right="10px">
      <div box-sizing="content-box" direction="ltr" width="10px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="30" height="30">
      <node x="10" y="10" width="10" height="10"/>
    </node>
  </expectations>
</test>
