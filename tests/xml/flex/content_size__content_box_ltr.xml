<test name="content_size__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" box-sizing="content-box" direction="ltr" flex-direction="column" overflow-y="scroll" scrollbar-width="15" width="100px" height="100px">
      <div box-sizing="content-box" direction="ltr" height="30px">
        <text box-sizing="content-box" direction="ltr" position="absolute" flex-shrink="0" width="100%" height="20px" top="-10px">
          HHHH​HHHH
        </text>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100" scroll_width="0" scroll_height="0">
      <node x="0" y="0" width="85" height="30">
        <node x="0" y="-10" width="85" height="20"/>
      </node>
    </node>
  </expectations>
</test>
