<test name="flex_basis_larger_than_content_row__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px">
      <div box-sizing="content-box" direction="rtl" flex-direction="column" flex-basis="50px">
        <div box-sizing="content-box" direction="rtl" width="10px" height="100px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="100">
        <node x="40" y="0" width="10" height="100"/>
      </node>
    </node>
  </expectations>
</test>
