<test name="flex_basis_smaller_than_main_dimen_row__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" width="100px">
      <div box-sizing="content-box" direction="rtl" flex-basis="10px" width="50px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="50">
      <node x="90" y="0" width="10" height="50"/>
    </node>
  </expectations>
</test>
