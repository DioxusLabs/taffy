<test name="display_none_with_position_absolute__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div display="none" direction="ltr" position="absolute" width="100px" height="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="0" height="0"/>
    </node>
  </expectations>
</test>
