<test name="align_baseline_multiline_row_and_column__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-wrap="wrap" align-items="baseline" width="100px" height="100px">
      <div box-sizing="content-box" direction="ltr" width="50px" height="50px"/>
      <div box-sizing="content-box" direction="ltr" flex-direction="column" width="50px" height="50px">
        <div box-sizing="content-box" direction="ltr" width="50px" height="10px"/>
      </div>
      <div box-sizing="content-box" direction="ltr" flex-direction="column" width="50px" height="20px">
        <div box-sizing="content-box" direction="ltr" width="50px" height="10px"/>
      </div>
      <div box-sizing="content-box" direction="ltr" width="50px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="50" height="50"/>
      <node x="50" y="40" width="50" height="50">
        <node x="0" y="0" width="50" height="10"/>
      </node>
      <node x="0" y="100" width="50" height="20">
        <node x="0" y="0" width="50" height="10"/>
      </node>
      <node x="50" y="90" width="50" height="20"/>
    </node>
  </expectations>
</test>
