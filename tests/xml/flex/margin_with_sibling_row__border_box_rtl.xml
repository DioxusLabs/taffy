<test name="margin_with_sibling_row__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" width="100px" height="100px">
      <div direction="rtl" flex-grow="1" margin-right="10px"/>
      <div direction="rtl" flex-grow="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="45" y="0" width="45" height="100"/>
      <node x="0" y="0" width="45" height="100"/>
    </node>
  </expectations>
</test>
