<test name="margin_bottom__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="ltr" flex-direction="column" justify-content="flex-end" width="100px" height="100px">
      <div box-sizing="content-box" direction="ltr" height="10px" margin-bottom="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="80" width="100" height="10"/>
    </node>
  </expectations>
</test>
