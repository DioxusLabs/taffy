<test name="margin_and_flex_row__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="ltr" width="100px" height="100px">
      <div direction="ltr" flex-grow="1" margin-left="10px" margin-right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="10" y="0" width="80" height="100"/>
    </node>
  </expectations>
</test>
