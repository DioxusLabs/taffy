<test name="flex_grow_child__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl">
      <div box-sizing="content-box" direction="rtl" flex-grow="1" flex-basis="0px" height="100px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="0" height="100">
      <node x="0" y="0" width="0" height="100"/>
    </node>
  </expectations>
</test>
