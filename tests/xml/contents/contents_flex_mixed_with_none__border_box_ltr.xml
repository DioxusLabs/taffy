<test name="contents_flex_mixed_with_none__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="flex" direction="ltr" width="200px" height="100px" justify-content="space-between">
      <div display="contents">
        <div direction="ltr" width="30px"/>
      </div>
      <div display="none">
        <div direction="ltr" width="30px"/>
      </div>
      <div direction="ltr" width="30px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="0" height="0">
        <node x="0" y="0" width="30" height="100"/>
      </node>
      <node x="0" y="0" width="0" height="0">
        <node x="0" y="0" width="0" height="0"/>
      </node>
      <node x="170" y="0" width="30" height="100"/>
    </node>
  </expectations>
</test>
