  <input>
    <div display="flex" box-sizing="content-box" direction="rtl" flex-direction="column" width="200px" height="50px">
      <div display="block" box-sizing="content-box" direction="rtl"/>
      <div display="block" box-sizing="content-box" direction="rtl" width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="50">
      <node x="0" y="0" width="200" height="0"/>
      <node x="150" y="0" width="50" height="0"/>
    </node>
  </expectations>
</test>
