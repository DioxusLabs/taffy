<test name="block_margin_y_last_child_collapse_blocked_by_overflow_y_scroll__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="50px">
      <div display="block" box-sizing="content-box" direction="rtl" overflow-y="scroll" scrollbar-width="15" margin-bottom="10px">
        <div display="block" box-sizing="content-box" direction="rtl" margin-bottom="10px">
          <div box-sizing="content-box" direction="rtl" height="10px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="30">
      <node x="0" y="0" width="50" height="20" scroll_width="0" scroll_height="0">
        <node x="15" y="0" width="35" height="10">
          <node x="0" y="0" width="35" height="10"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
