<test name="block_overflow_scrollbars_take_up_space_both_axis__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" overflow-x="scroll" overflow-y="scroll" scrollbar-width="15" width="50px" height="50px">
      <div box-sizing="content-box" direction="rtl" position="absolute" top="0px" left="0px" bottom="0px" right="0px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50" scroll_width="0" scroll_height="0">
      <node x="15" y="0" width="35" height="35"/>
    </node>
  </expectations>
</test>
