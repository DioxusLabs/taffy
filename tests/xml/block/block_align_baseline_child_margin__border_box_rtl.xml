<test name="block_align_baseline_child_margin__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" align-items="baseline" width="100px" height="100px">
      <div display="block" direction="rtl" width="50px" height="50px" margin-top="5px" margin-left="5px" margin-bottom="5px" margin-right="5px"/>
      <div display="block" direction="rtl" width="50px" height="20px">
        <div direction="rtl" width="50px" height="10px" margin-top="5px" margin-left="5px" margin-bottom="5px" margin-right="5px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="55" y="5" width="40" height="50"/>
      <node x="0" y="35" width="50" height="20">
        <node x="-5" y="5" width="50" height="10"/>
      </node>
    </node>
  </expectations>
</test>
