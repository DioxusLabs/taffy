<test name="block_absolute_minmax_bottom_right_max__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div display="block" box-sizing="content-box" direction="rtl" position="absolute" width="100px" height="100px" max-width="40px" max-height="30px" bottom="10px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="60" width="40" height="30"/>
    </node>
  </expectations>
</test>
