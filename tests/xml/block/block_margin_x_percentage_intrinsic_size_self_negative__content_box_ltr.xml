<test name="block_margin_x_percentage_intrinsic_size_self_negative__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr">
      <div box-sizing="content-box" direction="ltr" width="100px" height="10px" margin-left="-20%" margin-right="-10%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="10">
      <node x="-20" y="0" width="100" height="10"/>
    </node>
  </expectations>
</test>
