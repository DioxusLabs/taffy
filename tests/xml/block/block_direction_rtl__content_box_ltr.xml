<test name="block_direction_rtl__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px">
      <div box-sizing="content-box" direction="ltr" width="20px" height="10px"/>
      <div box-sizing="content-box" direction="ltr" width="50px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="20">
      <node x="80" y="0" width="20" height="10"/>
      <node x="50" y="10" width="50" height="10"/>
    </node>
  </expectations>
</test>
