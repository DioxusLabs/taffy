<test name="block_margin_auto_bottom__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" align-items="center" width="200px" height="200px">
      <div width="50px" height="50px" margin-bottom="auto"/>
      <div width="50px" height="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="50" height="50"/>
      <node x="0" y="50" width="50" height="50"/>
    </node>
  </expectations>
</test>
