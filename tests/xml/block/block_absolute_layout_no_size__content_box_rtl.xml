<test name="block_absolute_layout_no_size__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" position="absolute"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="100" y="0" width="0" height="0"/>
    </node>
  </expectations>
</test>
