<test name="block_padding_border_percentage_fixed_size__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="50px" height="50px">
      <div display="block" box-sizing="content-box" direction="rtl" padding-top="1%" padding-left="4%" padding-bottom="3%" padding-right="2%">
        <div display="block" box-sizing="content-box" direction="rtl" height="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50">
      <node x="0" y="0" width="50" height="12">
        <node x="2" y="1" width="47" height="10"/>
      </node>
    </node>
  </expectations>
</test>
