<test name="block_item_min_width_overrides_max_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" height="50px" min-width="200px" max-width="50px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="-100" y="0" width="200" height="50"/>
    </node>
  </expectations>
</test>
