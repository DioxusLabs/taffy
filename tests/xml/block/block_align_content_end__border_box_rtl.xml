<test name="block_align_content_end__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" align-content="end" width="100px" height="120px">
      <div direction="rtl" width="50px" height="20px"/>
      <div direction="rtl" width="50px" height="20px"/>
      <div direction="rtl" width="50px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="120">
      <node x="50" y="60" width="50" height="20"/>
      <node x="50" y="80" width="50" height="20"/>
      <node x="50" y="100" width="50" height="20"/>
    </node>
  </expectations>
</test>
