<test name="block_margin_x_fixed_auto_left_and_right__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" width="50px">
      <div width="20px" height="10px" margin-left="auto" margin-right="auto"/>
      <div height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="20">
      <node x="15" y="0" width="20" height="10"/>
      <node x="0" y="10" width="50" height="10"/>
    </node>
  </expectations>
</test>
