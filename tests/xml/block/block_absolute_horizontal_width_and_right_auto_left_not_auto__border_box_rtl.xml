<test name="block_absolute_horizontal_width_and_right_auto_left_not_auto__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" width="200px" height="200px">
      <text direction="rtl" position="absolute" height="100px" margin-top="100px" margin-left="auto" margin-right="auto" top="0px" left="20px" right="auto">
        
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="20" y="100" width="0" height="100"/>
    </node>
  </expectations>
</test>
