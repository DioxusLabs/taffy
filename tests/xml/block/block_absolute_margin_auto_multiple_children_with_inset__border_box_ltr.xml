<test name="block_absolute_margin_auto_multiple_children_with_inset__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="ltr" align-items="center" width="200px" height="200px">
      <div direction="ltr" position="absolute" width="100px" height="50px" margin-right="auto" left="10px" right="20px"/>
      <div direction="ltr" position="absolute" width="50px" height="50px" margin-right="auto" left="20px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="10" y="0" width="100" height="50"/>
      <node x="20" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
