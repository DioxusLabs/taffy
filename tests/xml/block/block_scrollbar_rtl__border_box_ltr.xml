<test name="block_scrollbar_rtl__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" overflow-y="scroll" scrollbar-width="15" width="100px" height="100px">
      <div direction="ltr" height="200px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100" scroll_width="0" scroll_height="100">
      <node x="15" y="0" width="85" height="200"/>
    </node>
  </expectations>
</test>
