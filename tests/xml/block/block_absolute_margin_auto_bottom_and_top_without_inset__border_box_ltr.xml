<test name="block_absolute_margin_auto_bottom_and_top_without_inset__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="ltr" width="200px" height="200px">
      <div direction="ltr" position="absolute" width="50px" height="50px" margin-top="auto" margin-bottom="auto"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
