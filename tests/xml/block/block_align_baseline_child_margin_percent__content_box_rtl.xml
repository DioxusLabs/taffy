<test name="block_align_baseline_child_margin_percent__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div box-sizing="content-box" direction="rtl" align-items="baseline" width="100px" height="100px">
      <div display="block" box-sizing="content-box" direction="rtl" width="50px" height="50px" margin-top="5%" margin-left="5%" margin-bottom="5%" margin-right="5%"/>
      <div display="block" box-sizing="content-box" direction="rtl" width="50px" height="20px">
        <div display="block" box-sizing="content-box" direction="rtl" width="50px" height="10px" margin-top="1%" margin-left="1%" margin-bottom="1%" margin-right="1%"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="55" y="5" width="40" height="50"/>
      <node x="0" y="35" width="50" height="20">
        <node x="0" y="1" width="50" height="10"/>
      </node>
    </node>
  </expectations>
</test>
