<test name="block_absolute_child_with_margin_y__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="20px" height="37px">
      <div box-sizing="content-box" direction="rtl" position="absolute" width="9px" height="9px" margin-top="7px"/>
      <div box-sizing="content-box" direction="rtl" position="absolute" width="9px" height="9px" margin-bottom="7px"/>
      <div box-sizing="content-box" direction="rtl" position="absolute" width="9px" height="9px" margin-top="10px" margin-bottom="5px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="20" height="37">
      <node x="11" y="7" width="9" height="9"/>
      <node x="11" y="0" width="9" height="9"/>
      <node x="11" y="10" width="9" height="9"/>
    </node>
  </expectations>
</test>
