<test name="block_align_content_start__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" align-content="start" width="100px" height="120px">
      <div direction="rtl" width="50px" height="20px"/>
      <div direction="rtl" width="50px" height="20px"/>
      <div direction="rtl" width="50px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="120">
      <node x="50" y="0" width="50" height="20"/>
      <node x="50" y="20" width="50" height="20"/>
      <node x="50" y="40" width="50" height="20"/>
    </node>
  </expectations>
</test>
