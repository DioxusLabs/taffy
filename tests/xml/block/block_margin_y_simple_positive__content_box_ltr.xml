<test name="block_margin_y_simple_positive__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr" width="50px">
      <div box-sizing="content-box" direction="ltr" height="10px" margin-top="10px" margin-bottom="10px"/>
      <div box-sizing="content-box" direction="ltr" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="40">
      <node x="0" y="10" width="50" height="10"/>
      <node x="0" y="30" width="50" height="10"/>
    </node>
  </expectations>
</test>
