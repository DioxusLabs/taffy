<test name="block_aspect_ratio_fill_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div display="block" box-sizing="content-box" direction="rtl" height="40px" aspect-ratio="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="20" y="0" width="80" height="40"/>
    </node>
  </expectations>
</test>
