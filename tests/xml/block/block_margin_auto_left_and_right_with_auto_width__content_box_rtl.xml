<test name="block_margin_auto_left_and_right_with_auto_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="200px" height="200px">
      <text box-sizing="content-box" direction="rtl" height="50px" max-width="100px" margin-left="auto" margin-right="auto">
        
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="50" y="0" width="100" height="50"/>
    </node>
  </expectations>
</test>
