<test name="block_display_none_with_margin__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" width="100px" height="100px">
      <div display="none" direction="rtl" width="20px" height="20px" margin-top="10px" margin-left="10px" margin-bottom="10px" margin-right="10px"/>
      <div direction="rtl" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="0" height="0"/>
      <node x="0" y="0" width="100" height="10"/>
    </node>
  </expectations>
</test>
