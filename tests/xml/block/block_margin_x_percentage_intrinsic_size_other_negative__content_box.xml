<test name="block_margin_x_percentage_intrinsic_size_other_negative__content_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box">
      <div box-sizing="content-box" height="10px" margin-left="-20%" margin-right="-10%"/>
      <div box-sizing="content-box" width="100px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="20">
      <node x="-20" y="0" width="130" height="10"/>
      <node x="0" y="10" width="100" height="10"/>
    </node>
  </expectations>
</test>
