<test name="block_align_content_safe_end_overflow__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" align-content="safe end" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" width="50px" height="80px"/>
      <div box-sizing="content-box" direction="rtl" width="50px" height="80px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="80"/>
      <node x="50" y="80" width="50" height="80"/>
    </node>
  </expectations>
</test>
