<test name="block_margin_y_collapse_through_blocked_by_overflow_x_scroll__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="50px">
      <div display="block" box-sizing="content-box" direction="rtl" height="10px" margin-bottom="10px"/>
      <div display="block" box-sizing="content-box" direction="rtl" overflow-x="scroll" scrollbar-width="15" margin-top="10px" margin-bottom="10px"/>
      <div display="block" box-sizing="content-box" direction="rtl" height="10px" margin-top="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="55">
      <node x="0" y="0" width="50" height="10"/>
      <node x="0" y="20" width="50" height="15" scroll_width="0" scroll_height="0"/>
      <node x="0" y="45" width="50" height="10"/>
    </node>
  </expectations>
</test>
