<test name="block_padding_rtl__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" padding-left="10px" padding-right="20px" border-left="5px" border-right="15px">
      <div box-sizing="content-box" direction="ltr" width="20px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="150" height="10">
      <node x="95" y="0" width="20" height="10"/>
    </node>
  </expectations>
</test>
