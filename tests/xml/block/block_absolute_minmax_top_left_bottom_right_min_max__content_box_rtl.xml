<test name="block_absolute_minmax_top_left_bottom_right_min_max__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div display="block" box-sizing="content-box" direction="rtl" position="absolute" min-width="50px" min-height="60px" max-width="40px" max-height="30px" top="10px" left="10px" bottom="10px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="40" y="10" width="50" height="60"/>
    </node>
  </expectations>
</test>
