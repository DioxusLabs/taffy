<test name="block_basic__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="50px">
      <div box-sizing="content-box" direction="rtl" height="10px"/>
      <div box-sizing="content-box" direction="rtl" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="20">
      <node x="0" y="0" width="50" height="10"/>
      <node x="0" y="10" width="50" height="10"/>
    </node>
  </expectations>
</test>
