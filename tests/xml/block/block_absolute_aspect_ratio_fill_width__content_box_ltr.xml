<test name="block_absolute_aspect_ratio_fill_width__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr" width="400px" height="300px">
      <div box-sizing="content-box" direction="ltr" position="absolute" height="20%" aspect-ratio="3" top="5%" left="5%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="400" height="300">
      <node x="20" y="15" width="180" height="60"/>
    </node>
  </expectations>
</test>
