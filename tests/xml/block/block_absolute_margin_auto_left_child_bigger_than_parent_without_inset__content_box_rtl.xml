<test name="block_absolute_margin_auto_left_child_bigger_than_parent_without_inset__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="52px" height="52px">
      <div box-sizing="content-box" direction="rtl" position="absolute" width="72px" height="72px" margin-left="auto"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="52" height="52">
      <node x="-20" y="0" width="72" height="72"/>
    </node>
  </expectations>
</test>
