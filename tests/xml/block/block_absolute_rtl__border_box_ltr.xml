<test name="block_absolute_rtl__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" width="100px" height="100px">
      <div direction="ltr" position="absolute" width="20px" height="20px" top="10px" left="10px"/>
      <div direction="ltr" position="absolute" width="20px" height="20px" top="40px" right="10px"/>
      <div direction="ltr" position="absolute" width="20px" height="20px" top="70px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="10" y="10" width="20" height="20"/>
      <node x="70" y="40" width="20" height="20"/>
      <node x="80" y="70" width="20" height="20"/>
    </node>
  </expectations>
</test>
