<test name="block_margin_y_last_child_collapse_not_blocked_by_padding_top__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="50px">
      <div display="block" box-sizing="content-box" direction="rtl" margin-bottom="10px" padding-top="1px">
        <div display="block" box-sizing="content-box" direction="rtl" margin-bottom="10px">
          <div box-sizing="content-box" direction="rtl" height="10px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="21">
      <node x="0" y="0" width="50" height="11">
        <node x="0" y="1" width="50" height="10">
          <node x="0" y="0" width="50" height="10"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
