<test name="block_inset_percentage__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="ltr" width="50px">
      <div direction="ltr" height="10px" top="4%" left="2%"/>
      <div direction="ltr" height="10px" bottom="8%" right="6%"/>
      <div direction="ltr" height="10px" top="4%" left="2%" bottom="8%" right="6%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="30">
      <node x="1" y="0" width="50" height="10"/>
      <node x="-3" y="10" width="50" height="10"/>
      <node x="1" y="20" width="50" height="10"/>
    </node>
  </expectations>
</test>
