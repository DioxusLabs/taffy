<test name="block_item_max_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="200px" height="200px">
      <div box-sizing="content-box" direction="rtl" height="50px" max-width="100px"/>
      <div box-sizing="content-box" direction="rtl" height="50px" max-width="300px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="100" y="0" width="100" height="50"/>
      <node x="0" y="50" width="200" height="50"/>
    </node>
  </expectations>
</test>
