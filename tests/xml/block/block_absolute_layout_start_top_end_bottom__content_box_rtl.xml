<test name="block_absolute_layout_start_top_end_bottom__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div display="block" box-sizing="content-box" direction="rtl" position="absolute" top="10px" left="10px" bottom="10px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="10" y="10" width="80" height="80"/>
    </node>
  </expectations>
</test>
