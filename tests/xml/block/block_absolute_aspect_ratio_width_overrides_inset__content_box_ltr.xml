<test name="block_absolute_aspect_ratio_width_overrides_inset__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr" width="400px" height="300px">
      <div box-sizing="content-box" direction="ltr" position="absolute" width="40%" aspect-ratio="3" top="5%" left="10%" right="10%"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="400" height="300">
      <node x="40" y="15" width="160" height="53"/>
    </node>
  </expectations>
</test>
