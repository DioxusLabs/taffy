<test name="block_margin_x_percentage_intrinsic_size_other_positive__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr">
      <div box-sizing="content-box" direction="ltr" height="10px" margin-left="20%" margin-right="10%"/>
      <div box-sizing="content-box" direction="ltr" width="100px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="20">
      <node x="20" y="0" width="70" height="10"/>
      <node x="0" y="10" width="100" height="10"/>
    </node>
  </expectations>
</test>
