<test name="block_absolute_margin_bottom_left_with_inset__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" width="100px" height="100px">
      <div display="block" direction="rtl" position="absolute" width="10px" height="10px" margin-left="10px" margin-bottom="10px" top="10px" left="20px" bottom="20px" right="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="80" y="10" width="10" height="10"/>
    </node>
  </expectations>
</test>
