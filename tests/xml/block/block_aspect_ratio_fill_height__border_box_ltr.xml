    <div display="block" direction="ltr" width="100px" height="100px">
      <div display="block" direction="ltr" width="40px" aspect-ratio="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="40" height="20"/>
    </node>
  </expectations>
</test>
