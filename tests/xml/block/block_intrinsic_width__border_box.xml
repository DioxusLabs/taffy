<test name="block_intrinsic_width__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block">
      <div width="50px" height="10px"/>
      <div height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="20">
      <node x="0" y="0" width="50" height="10"/>
      <node x="0" y="10" width="50" height="10"/>
    </node>
  </expectations>
</test>
