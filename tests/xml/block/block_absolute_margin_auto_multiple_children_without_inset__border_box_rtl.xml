<test name="block_absolute_margin_auto_multiple_children_without_inset__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" align-items="center" width="200px" height="200px">
      <div direction="rtl" position="absolute" width="100px" height="50px" margin-right="auto"/>
      <div direction="rtl" position="absolute" width="50px" height="50px" margin-right="auto"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="100" y="0" width="100" height="50"/>
      <node x="150" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
