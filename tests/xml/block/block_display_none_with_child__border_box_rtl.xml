<test name="block_display_none_with_child__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="rtl" width="100px" height="100px">
      <div direction="rtl" height="10px"/>
      <div display="none" direction="rtl">
        <div direction="rtl" width="20px" height="10px"/>
      </div>
      <div direction="rtl" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="10"/>
      <node x="0" y="0" width="0" height="0">
        <node x="0" y="0" width="0" height="0"/>
      </node>
      <node x="0" y="10" width="100" height="10"/>
    </node>
  </expectations>
</test>
