<test name="block_align_content_stretch_single_child__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="ltr" align-content="stretch" width="100px" height="120px">
      <div box-sizing="content-box" direction="ltr" width="50px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="120">
      <node x="0" y="0" width="50" height="20"/>
    </node>
  </expectations>
</test>
