<test name="block_align_baseline_child_top__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div direction="rtl" align-items="baseline" width="100px" height="100px">
      <div display="block" direction="rtl" width="50px" height="50px" top="10px"/>
      <div display="block" direction="rtl" width="50px" height="20px">
        <div display="block" direction="rtl" width="50px" height="10px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="10" width="50" height="50"/>
      <node x="0" y="30" width="50" height="20">
        <node x="0" y="0" width="50" height="10"/>
      </node>
    </node>
  </expectations>
</test>
