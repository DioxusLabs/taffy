<test name="block_margin_x_intrinsic_size_negative__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" direction="ltr">
      <div direction="ltr" height="10px" margin-left="-10px" margin-right="-5px"/>
      <div direction="ltr" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="0" height="20">
      <node x="-10" y="0" width="15" height="10"/>
      <node x="0" y="10" width="0" height="10"/>
    </node>
  </expectations>
</test>
