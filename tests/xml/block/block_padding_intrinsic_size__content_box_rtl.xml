<test name="block_padding_intrinsic_size__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="block" box-sizing="content-box" direction="rtl" padding-top="2px" padding-left="8px" padding-bottom="6px" padding-right="4px">
      <div box-sizing="content-box" direction="rtl" width="50px" height="10px"/>
      <div box-sizing="content-box" direction="rtl" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="62" height="28">
      <node x="8" y="2" width="50" height="10"/>
      <node x="8" y="12" width="50" height="10"/>
    </node>
  </expectations>
</test>
