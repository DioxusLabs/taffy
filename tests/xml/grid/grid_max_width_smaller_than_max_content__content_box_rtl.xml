      <div display="grid" box-sizing="content-box" direction="rtl" max-width="80px" grid-template-columns="auto auto">
        <text box-sizing="content-box" direction="rtl">
          HH​HH​HH​HH
        </text>
        <text box-sizing="content-box" direction="rtl">
          HH​HH​HH​HH
        </text>
      </div>
    </div>
