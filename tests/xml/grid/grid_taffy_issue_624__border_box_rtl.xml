<test name="grid_taffy_issue_624__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" justify-items="start" justify-content="start" width="320px" height="640px" grid-template-rows="auto auto auto 1fr" grid-template-columns="auto auto 1fr">
      <div direction="rtl" width="100px" height="50px" grid-row-start="1" grid-row-end="span 2" grid-column-start="1"/>
      <div direction="rtl" width="40px" height="30px" grid-row-start="1" grid-row-end="span 2" grid-column-start="2" grid-column-end="span 2"/>
      <div direction="rtl" width="120px" height="20px" grid-row-start="3" grid-row-end="span 1" grid-column-start="1" grid-column-end="span 2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="320" height="640">
      <node x="220" y="0" width="100" height="50"/>
      <node x="180" y="0" width="40" height="30"/>
      <node x="200" y="50" width="120" height="20"/>
    </node>
  </expectations>
</test>
