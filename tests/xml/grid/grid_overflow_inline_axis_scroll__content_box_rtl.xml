<test name="grid_overflow_inline_axis_scroll__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" width="50px" height="50px">
      <text box-sizing="content-box" direction="rtl" overflow-x="scroll" overflow-y="scroll" scrollbar-width="15">
        HHHHHHHHHH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="50" height="50">
      <node x="0" y="0" width="50" height="50" scroll_width="65" scroll_height="0"/>
    </node>
  </expectations>
</test>
