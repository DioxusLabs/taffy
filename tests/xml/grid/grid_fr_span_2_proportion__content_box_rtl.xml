<test name="grid_fr_span_2_proportion__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="40px 40px" grid-template-columns="1fr 2fr">
      <div box-sizing="content-box" direction="rtl" width="60px" grid-column-start="span 2"/>
      <div box-sizing="content-box" direction="rtl"/>
      <div box-sizing="content-box" direction="rtl"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="80">
      <node x="0" y="0" width="60" height="40"/>
      <node x="40" y="40" width="20" height="40"/>
      <node x="0" y="40" width="40" height="40"/>
    </node>
  </expectations>
</test>
