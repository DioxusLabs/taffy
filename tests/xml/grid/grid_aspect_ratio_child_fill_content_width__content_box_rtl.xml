<test name="grid_aspect_ratio_child_fill_content_width__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl">
      <text box-sizing="content-box" direction="rtl" aspect-ratio="2">
        HHHH
      </text>
      <div box-sizing="content-box" direction="rtl" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="40" height="40">
      <node x="0" y="0" width="40" height="20"/>
      <node x="0" y="20" width="40" height="20"/>
    </node>
  </expectations>
</test>
