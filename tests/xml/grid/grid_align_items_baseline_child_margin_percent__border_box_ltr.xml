<test name="grid_align_items_baseline_child_margin_percent__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" align-items="baseline" width="100px" height="100px">
      <div display="grid" direction="ltr" width="50px" height="50px" margin-top="5%" margin-left="5%" margin-bottom="5%" margin-right="5%"/>
      <div display="grid" direction="ltr" width="50px" height="20px">
        <div display="grid" direction="ltr" width="50px" height="10px" margin-top="1%" margin-left="1%" margin-bottom="1%" margin-right="1%"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="5" y="5" width="50" height="50"/>
      <node x="0" y="70" width="50" height="20">
        <node x="1" y="1" width="50" height="10"/>
      </node>
    </node>
  </expectations>
</test>
