  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" width="100px" height="100px">
      <text box-sizing="content-box" direction="ltr" writing-mode="vertical-lr" max-width="40px" aspect-ratio="2">
        HH​HH​HH​HH​HH​HH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="40" height="20"/>
    </node>
  </expectations>
</test>
