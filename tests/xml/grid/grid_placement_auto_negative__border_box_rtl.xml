<test name="grid_placement_auto_negative__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="120px" height="120px" grid-template-rows="40px 40px" grid-template-columns="40px 40px">
      <div direction="rtl" grid-row-start="1" grid-column-start="-5"/>
      <div direction="rtl"/>
      <div direction="rtl" grid-row-start="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="100" y="0" width="20" height="40"/>
      <node x="80" y="0" width="20" height="40"/>
      <node x="100" y="40" width="20" height="40"/>
    </node>
  </expectations>
</test>
