<test name="grid_overlarge_huge_repeat_count__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="90px" grid-template-columns="repeat(32768, fit-content(512px)) fit-content(100%)">
      <div box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="20" height="90">
      <node x="0" y="0" width="20" height="20"/>
    </node>
  </expectations>
</test>
