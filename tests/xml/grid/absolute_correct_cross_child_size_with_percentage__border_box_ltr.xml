<test name="absolute_correct_cross_child_size_with_percentage__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="300px" height="110px">
      <div display="flex" direction="ltr" position="absolute" flex-direction="column" top="40px" left="50px">
        <div direction="ltr" width="200px" height="10px"/>
        <div direction="ltr" width="100%" height="10px"/>
        <div display="flex" direction="ltr" width="100%" height="10px">
          <div direction="ltr" width="10px" height="10px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="300" height="110">
      <node x="50" y="40" width="200" height="30">
        <node x="0" y="0" width="200" height="10"/>
        <node x="0" y="10" width="200" height="10"/>
        <node x="0" y="20" width="200" height="10">
          <node x="0" y="0" width="10" height="10"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
