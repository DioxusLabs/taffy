<test name="grid_absolute_layout_within_border_static__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" width="100px" height="100px" padding-top="10px" padding-left="10px" padding-bottom="10px" padding-right="10px" border-top="10px" border-left="10px" border-bottom="10px" border-right="10px">
      <div box-sizing="content-box" direction="ltr" position="absolute" align-self="start" justify-self="start" width="50px" height="50px"/>
      <div box-sizing="content-box" direction="ltr" position="absolute" align-self="end" justify-self="end" width="50px" height="50px"/>
      <div box-sizing="content-box" direction="ltr" position="absolute" align-self="start" justify-self="start" width="50px" height="50px" margin-top="10px" margin-left="10px" margin-bottom="10px" margin-right="10px"/>
