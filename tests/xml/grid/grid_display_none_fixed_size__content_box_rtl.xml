<test name="grid_display_none_fixed_size__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" width="100px" height="100px">
      <div box-sizing="content-box" direction="rtl" flex-grow="1"/>
      <div display="none" box-sizing="content-box" direction="rtl" width="20px" height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="100"/>
      <node x="0" y="0" width="0" height="0"/>
    </node>
  </expectations>
</test>
