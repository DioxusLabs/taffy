<test name="grid_justify_self_rtl__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="100px" grid-template-columns="100px">
      <div direction="ltr" justify-self="start" width="20px" height="10px"/>
      <div direction="ltr" justify-self="end" width="20px" height="10px"/>
      <div direction="ltr" justify-self="center" width="20px" height="10px"/>
      <div direction="ltr" justify-self="stretch" width="20px" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="40">
      <node x="80" y="0" width="20" height="10"/>
      <node x="0" y="10" width="20" height="10"/>
      <node x="40" y="20" width="20" height="10"/>
      <node x="80" y="30" width="20" height="10"/>
    </node>
  </expectations>
</test>
