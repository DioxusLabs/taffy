<test name="grid_fit_content_percent_indefinite_max_content_hidden__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="40px" grid-template-columns="fit-content(50%)">
      <text box-sizing="content-box" direction="ltr" overflow-x="hidden" overflow-y="hidden" scrollbar-width="15">
        HH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="20" height="40">
      <node x="0" y="0" width="10" height="40" scroll_width="10" scroll_height="0"/>
    </node>
  </expectations>
</test>
