<test name="grid_percent_item_inside_stretch_item__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" width="100px" height="100px">
      <div display="grid">
        <div display="grid" width="50%"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="100">
        <node x="0" y="0" width="50" height="100"/>
      </node>
    </node>
  </expectations>
</test>
