  <input>
    <div display="grid" direction="ltr" grid-template-columns="auto auto">
      <text direction="ltr">
        HH​HH​HH​HH
      </text>
      <text direction="ltr">
        HH​HH​HH​HH
      </text>
    </div>
  </input>
  <expectations>
