<test name="grid_percent_tracks_indefinite_with_content_underflow__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="30% 60%" grid-template-columns="10% 20% 30%">
      <div box-sizing="content-box" direction="rtl" width="100px" height="100px" grid-row-start="1" grid-column-start="1"/>
      <div box-sizing="content-box" direction="rtl" grid-row-start="1" grid-column-start="1"/>
      <div box-sizing="content-box" direction="rtl"/>
      <div box-sizing="content-box" direction="rtl"/>
      <div box-sizing="content-box" direction="rtl"/>
      <div box-sizing="content-box" direction="rtl"/>
      <div box-sizing="content-box" direction="rtl"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="0" y="0" width="100" height="100"/>
      <node x="90" y="0" width="10" height="30"/>
      <node x="70" y="0" width="20" height="30"/>
      <node x="40" y="0" width="30" height="30"/>
      <node x="90" y="30" width="10" height="60"/>
      <node x="70" y="30" width="20" height="60"/>
      <node x="40" y="30" width="30" height="60"/>
    </node>
  </expectations>
</test>
