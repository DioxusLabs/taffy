<test name="grid_margins_percent_stretch__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" grid-template-rows="40px 40px 40px" grid-template-columns="20px 20px 20px">
      <div direction="rtl" align-self="stretch" justify-self="stretch" width="20px" height="20px" margin-top="5%" margin-left="20%" margin-bottom="15%" margin-right="10%"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="120">
      <node x="38" y="1" width="20" height="20"/>
      <node x="20" y="0" width="20" height="40"/>
      <node x="0" y="0" width="20" height="40"/>
      <node x="40" y="40" width="20" height="40"/>
      <node x="20" y="40" width="20" height="40"/>
      <node x="0" y="40" width="20" height="40"/>
    </node>
  </expectations>
</test>
