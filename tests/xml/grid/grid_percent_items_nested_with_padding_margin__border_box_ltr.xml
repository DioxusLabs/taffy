<test name="grid_percent_items_nested_with_padding_margin__border_box_ltr" use-rounding="false">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="200px" height="200px" grid-template-rows="1fr 4fr">
      <div display="grid" direction="ltr" min-width="60%" margin-top="5px" margin-left="5px" margin-bottom="5px" margin-right="5px" padding-top="3px" padding-left="3px" padding-bottom="3px" padding-right="3px">
        <div display="grid" direction="ltr" width="50%" margin-top="5px" margin-left="5px" margin-bottom="5px" margin-right="5px" padding-top="3%" padding-left="3%" padding-bottom="3%" padding-right="3%">
          <div direction="ltr" width="45%" margin-top="5%" margin-left="5%" margin-bottom="5%" margin-right="5%" padding-top="3px" padding-left="3px" padding-bottom="3px" padding-right="3px"/>
        </div>
      </div>
      <div direction="ltr"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="5" y="5" width="190" height="41.125">
        <node x="8" y="8" width="92" height="25.125">
          <node x="9.5625" y="9.5625" width="36.421875" height="6"/>
        </node>
      </node>
      <node x="0" y="51.125" width="200" height="148.875"/>
    </node>
  </expectations>
</test>
