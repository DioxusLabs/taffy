<test name="grid_placement_auto_negative__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="120px" height="120px" grid-template-rows="40px 40px" grid-template-columns="40px 40px">
      <div direction="ltr" grid-row-start="1" grid-column-start="-5"/>
      <div direction="ltr"/>
      <div direction="ltr" grid-row-start="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="0" y="0" width="20" height="40"/>
      <node x="20" y="0" width="20" height="40"/>
      <node x="0" y="40" width="20" height="40"/>
    </node>
  </expectations>
</test>
