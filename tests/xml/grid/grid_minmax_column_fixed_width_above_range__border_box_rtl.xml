<test name="grid_minmax_column_fixed_width_above_range__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="140px" grid-template-rows="40px 40px 40px" grid-template-columns="40px minmax(20px,40px) 40px">
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
      <div direction="rtl"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="140" height="120">
      <node x="100" y="0" width="40" height="40"/>
      <node x="60" y="0" width="40" height="40"/>
      <node x="20" y="0" width="40" height="40"/>
      <node x="100" y="40" width="40" height="40"/>
      <node x="60" y="40" width="40" height="40"/>
      <node x="20" y="40" width="40" height="40"/>
      <node x="100" y="80" width="40" height="40"/>
      <node x="60" y="80" width="40" height="40"/>
      <node x="20" y="80" width="40" height="40"/>
    </node>
  </expectations>
</test>
