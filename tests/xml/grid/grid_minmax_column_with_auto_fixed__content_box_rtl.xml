<test name="grid_minmax_column_with_auto_fixed__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" width="60px" grid-template-rows="40px" grid-template-columns="minmax(20px,40px) auto">
      <div box-sizing="content-box" direction="rtl"/>
      <div box-sizing="content-box" direction="rtl"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="40">
      <node x="20" y="0" width="40" height="40"/>
      <node x="0" y="0" width="20" height="40"/>
    </node>
  </expectations>
</test>
