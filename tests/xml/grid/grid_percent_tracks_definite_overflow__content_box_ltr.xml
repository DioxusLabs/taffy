<test name="grid_percent_tracks_definite_overflow__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" width="120px" height="60px" grid-template-rows="50% 80%" grid-template-columns="40% 40% 40%">
      <div box-sizing="content-box" direction="ltr"/>
      <div box-sizing="content-box" direction="ltr"/>
      <div box-sizing="content-box" direction="ltr"/>
      <div box-sizing="content-box" direction="ltr"/>
      <div box-sizing="content-box" direction="ltr"/>
      <div box-sizing="content-box" direction="ltr"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="60">
      <node x="0" y="0" width="48" height="30"/>
      <node x="48" y="0" width="48" height="30"/>
      <node x="96" y="0" width="48" height="30"/>
      <node x="0" y="30" width="48" height="48"/>
      <node x="48" y="30" width="48" height="48"/>
      <node x="96" y="30" width="48" height="48"/>
    </node>
  </expectations>
</test>
