<test name="grid_minmax_column_with_auto_fixed__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="60px" grid-template-rows="40px" grid-template-columns="minmax(20px,40px) auto">
      <div direction="ltr"/>
      <div direction="ltr"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="40">
      <node x="0" y="0" width="40" height="40"/>
      <node x="40" y="0" width="20" height="40"/>
    </node>
  </expectations>
</test>
