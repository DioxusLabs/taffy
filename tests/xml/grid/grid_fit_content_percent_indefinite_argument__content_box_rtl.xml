  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="40px" grid-template-columns="fit-content(50%)">
      <text box-sizing="content-box" direction="rtl">
        HH​HH​HH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="60" height="40">
      <node x="30" y="0" width="30" height="40"/>
    </node>
  </expectations>
</test>
