<test name="grid_aspect_ratio_child_fill_content_width__border_box" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid">
      <text aspect-ratio="2">
        HHHH
      </text>
      <div height="20px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="40" height="40">
      <node x="0" y="0" width="40" height="20"/>
      <node x="0" y="20" width="40" height="20"/>
    </node>
  </expectations>
</test>
