<test name="grid_percent_items_100_percent_2_col_auto__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="200px" grid-template-rows="50px 50px" grid-template-columns="auto auto">
      <div direction="ltr" width="100%" height="50px"/>
      <div direction="ltr" width="100%" height="50px" grid-row-start="2" grid-column-start="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="100" height="50"/>
      <node x="100" y="50" width="100" height="50"/>
    </node>
  </expectations>
</test>
