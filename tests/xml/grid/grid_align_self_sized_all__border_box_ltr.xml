<test name="grid_align_self_sized_all__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="120px" height="120px" grid-template-rows="40px 40px 40px" grid-template-columns="40px 40px 40px">
      <div direction="ltr" align-self="start" width="20px" height="20px"/>
      <div direction="ltr" align-self="start" width="60px" height="60px"/>
      <div direction="ltr" align-self="end" width="20px" height="20px"/>
      <div direction="ltr" align-self="end" width="60px" height="60px"/>
      <div direction="ltr" align-self="center" width="20px" height="20px"/>
      <div direction="ltr" align-self="center" width="60px" height="60px"/>
      <div direction="ltr" align-self="stretch" width="20px" height="20px"/>
      <div direction="ltr" align-self="stretch" width="60px" height="60px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="0" y="0" width="20" height="20"/>
      <node x="40" y="0" width="60" height="60"/>
      <node x="80" y="20" width="20" height="20"/>
      <node x="0" y="20" width="60" height="60"/>
      <node x="40" y="50" width="20" height="20"/>
      <node x="80" y="30" width="60" height="60"/>
      <node x="0" y="80" width="20" height="20"/>
      <node x="40" y="80" width="60" height="60"/>
    </node>
  </expectations>
</test>
