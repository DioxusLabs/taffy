<test name="grid_justify_items_sized_end__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" justify-items="end" width="120px" height="120px" grid-template-rows="40px 40px 40px" grid-template-columns="40px 40px 40px">
      <div direction="ltr" width="20px" height="20px" grid-row-start="1" grid-column-start="1"/>
      <div direction="ltr" width="60px" height="60px" grid-row-start="3" grid-column-start="3"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="20" y="0" width="20" height="20"/>
      <node x="60" y="80" width="60" height="60"/>
    </node>
  </expectations>
</test>
