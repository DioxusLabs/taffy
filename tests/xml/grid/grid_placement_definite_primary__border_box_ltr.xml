<test name="grid_placement_definite_primary__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="200px" height="200px" grid-template-columns="33% 74%">
      <div direction="ltr" grid-column-start="1"/>
      <div direction="ltr" grid-column-start="2"/>
      <div direction="ltr" grid-column-start="1"/>
      <div direction="ltr" grid-column-start="2"/>
      <div direction="ltr" grid-column-start="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="200">
      <node x="0" y="0" width="66" height="67"/>
      <node x="66" y="0" width="148" height="67"/>
      <node x="0" y="67" width="66" height="66"/>
      <node x="66" y="67" width="148" height="66"/>
      <node x="0" y="133" width="66" height="67"/>
    </node>
  </expectations>
</test>
