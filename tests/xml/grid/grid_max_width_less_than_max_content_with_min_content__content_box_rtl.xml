<test name="grid_max_width_less_than_max_content_with_min_content__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" grid-template-columns="min-content">
      <div display="grid" box-sizing="content-box" direction="rtl" max-width="80px" grid-template-columns="auto auto">
        <text box-sizing="content-box" direction="rtl">
          HH​HH​HH​HH
        </text>
        <text box-sizing="content-box" direction="rtl">
          HH​HH​HH​HH
        </text>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="40" height="40">
      <node x="0" y="0" width="40" height="40">
        <node x="20" y="0" width="20" height="40"/>
        <node x="0" y="0" width="20" height="40"/>
      </node>
    </node>
  </expectations>
</test>
