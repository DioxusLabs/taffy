<test name="grid_aspect_ratio_overridden_by_explicit_sizes__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="100px" height="100px">
      <div direction="rtl" width="50px" height="50px" aspect-ratio="2"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="100">
      <node x="50" y="0" width="50" height="50"/>
    </node>
  </expectations>
</test>
