<test name="grid_columns_rtl__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" width="100px" grid-template-columns="20px 40px 10px">
      <div box-sizing="content-box" direction="ltr" height="10px"/>
      <div box-sizing="content-box" direction="ltr" height="10px"/>
      <div box-sizing="content-box" direction="ltr" height="10px"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="10">
      <node x="80" y="0" width="20" height="10"/>
      <node x="40" y="0" width="40" height="10"/>
      <node x="30" y="0" width="10" height="10"/>
    </node>
  </expectations>
</test>
