<test name="grid_relayout_vertical_text__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="40px" grid-template-columns="min-content">
      <text box-sizing="content-box" direction="ltr" writing-mode="vertical-lr">
        HH​HH​HH​HH​HH​HH​HH
      </text>
      <text box-sizing="content-box" direction="ltr">
        HH​HH​HH
      </text>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="40" height="60">
      <node x="0" y="0" width="40" height="40"/>
      <node x="0" y="40" width="40" height="20"/>
    </node>
  </expectations>
</test>
