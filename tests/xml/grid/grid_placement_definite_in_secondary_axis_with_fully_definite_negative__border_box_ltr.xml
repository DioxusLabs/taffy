<test name="grid_placement_definite_in_secondary_axis_with_fully_definite_negative__border_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="ltr" width="120px" height="120px" grid-template-rows="40px 40px" grid-template-columns="40px 40px">
      <div direction="ltr" grid-row-start="2"/>
      <div direction="ltr" grid-row-start="2" grid-column-start="-4"/>
      <div direction="ltr" grid-row-start="1"/>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="120" height="120">
      <node x="40" y="40" width="40" height="40"/>
      <node x="0" y="40" width="40" height="40"/>
      <node x="0" y="0" width="40" height="40"/>
    </node>
  </expectations>
</test>
