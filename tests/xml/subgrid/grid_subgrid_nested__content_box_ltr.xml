<test name="grid_subgrid_nested__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="50px" grid-template-columns="auto auto">
      <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="50px" grid-template-columns="subgrid" grid-column-start="1" grid-column-end="3">
        <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="50px" grid-template-columns="subgrid" grid-column-start="1" grid-column-end="3">
          <div box-sizing="content-box" direction="ltr" width="40px"/>
          <div box-sizing="content-box" direction="ltr" width="60px"/>
        </div>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="100" height="50">
      <node x="0" y="0" width="100" height="50">
        <node x="0" y="0" width="100" height="50">
          <node x="0" y="0" width="40" height="50"/>
          <node x="40" y="0" width="60" height="50"/>
        </node>
      </node>
    </node>
  </expectations>
</test>
