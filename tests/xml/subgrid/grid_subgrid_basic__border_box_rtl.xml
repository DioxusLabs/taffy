<test name="grid_subgrid_basic__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="320px" height="200px" grid-template-rows="100px 100px" grid-template-columns="100px 100px 120px">
      <div display="grid" direction="rtl" grid-template-rows="subgrid" grid-template-columns="subgrid" grid-row-start="1" grid-row-end="3" grid-column-start="1" grid-column-end="3">
        <div direction="rtl"/>
        <div direction="rtl"/>
        <div direction="rtl"/>
        <div direction="rtl"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="320" height="200">
      <node x="120" y="0" width="200" height="200">
        <node x="100" y="0" width="100" height="100"/>
        <node x="0" y="0" width="100" height="100"/>
        <node x="100" y="100" width="100" height="100"/>
        <node x="0" y="100" width="100" height="100"/>
      </node>
    </node>
  </expectations>
</test>
