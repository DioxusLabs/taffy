<test name="grid_subgrid_placement_clamped__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="200px" height="100px" grid-template-rows="100px" grid-template-columns="100px 100px">
      <div display="grid" direction="rtl" grid-template-rows="subgrid" grid-template-columns="subgrid" grid-row-start="1" grid-row-end="2" grid-column-start="1" grid-column-end="3">
        <div direction="rtl"/>
        <div direction="rtl" grid-column-start="5" grid-column-end="7"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="100">
      <node x="0" y="0" width="200" height="100">
        <node x="100" y="0" width="100" height="100"/>
        <node x="0" y="0" width="100" height="100"/>
      </node>
    </node>
  </expectations>
</test>
