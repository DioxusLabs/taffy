<test name="grid_subgrid_columns__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" width="300px" height="200px" grid-template-rows="200px" grid-template-columns="100px 200px">
      <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="50px 70px" grid-template-columns="subgrid" grid-column-start="1" grid-column-end="3">
        <div box-sizing="content-box" direction="rtl"/>
        <div box-sizing="content-box" direction="rtl"/>
        <div box-sizing="content-box" direction="rtl"/>
        <div box-sizing="content-box" direction="rtl"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="300" height="200">
      <node x="0" y="0" width="300" height="200">
        <node x="200" y="0" width="100" height="50"/>
        <node x="0" y="0" width="200" height="50"/>
        <node x="200" y="50" width="100" height="70"/>
        <node x="0" y="50" width="200" height="70"/>
      </node>
    </node>
  </expectations>
</test>
