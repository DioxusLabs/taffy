<test name="grid_subgrid_auto_flow_wrap__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" width="200px" grid-template-columns="100px 100px" grid-auto-rows="40px">
      <div display="grid" box-sizing="content-box" direction="ltr" grid-template-columns="subgrid" grid-auto-rows="30px" grid-column-start="1" grid-column-end="3">
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="40">
      <node x="0" y="0" width="200" height="40">
        <node x="0" y="0" width="100" height="30"/>
        <node x="100" y="0" width="100" height="30"/>
        <node x="0" y="30" width="100" height="30"/>
        <node x="100" y="30" width="100" height="30"/>
        <node x="0" y="60" width="100" height="30"/>
      </node>
    </node>
  </expectations>
</test>
