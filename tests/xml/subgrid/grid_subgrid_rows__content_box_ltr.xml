<test name="grid_subgrid_rows__content_box_ltr" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="ltr" width="200px" height="300px" grid-template-rows="100px 200px" grid-template-columns="200px">
      <div display="grid" box-sizing="content-box" direction="ltr" grid-template-rows="subgrid" grid-template-columns="50px 70px" grid-row-start="1" grid-row-end="3">
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
        <div box-sizing="content-box" direction="ltr"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="200" height="300">
      <node x="0" y="0" width="200" height="300">
        <node x="0" y="0" width="50" height="100"/>
        <node x="50" y="0" width="70" height="100"/>
        <node x="0" y="100" width="50" height="200"/>
        <node x="50" y="100" width="70" height="200"/>
      </node>
    </node>
  </expectations>
</test>
