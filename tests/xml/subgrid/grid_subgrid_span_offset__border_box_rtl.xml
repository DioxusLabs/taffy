<test name="grid_subgrid_span_offset__border_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" direction="rtl" width="400px" height="100px" grid-template-rows="100px" grid-template-columns="50px 100px 150px 100px">
      <div display="grid" direction="rtl" grid-template-rows="subgrid" grid-template-columns="subgrid" grid-row-start="1" grid-row-end="2" grid-column-start="2" grid-column-end="4">
        <div direction="rtl"/>
        <div direction="rtl"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="400" height="100">
      <node x="100" y="0" width="250" height="100">
        <node x="150" y="0" width="100" height="100"/>
        <node x="0" y="0" width="150" height="100"/>
      </node>
    </node>
  </expectations>
</test>
