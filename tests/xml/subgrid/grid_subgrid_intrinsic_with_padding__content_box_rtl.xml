<test name="grid_subgrid_intrinsic_with_padding__content_box_rtl" use-rounding="true">
  <viewport width="max-content" height="max-content"/>
  <input>
    <div display="grid" box-sizing="content-box" direction="rtl" grid-template-rows="auto" grid-template-columns="auto">
      <div display="grid" box-sizing="content-box" direction="rtl" padding-top="0px" padding-left="10px" padding-bottom="0px" padding-right="10px" grid-template-rows="30px" grid-template-columns="subgrid" grid-column-start="1" grid-column-end="2">
        <div box-sizing="content-box" direction="rtl" width="50px"/>
      </div>
    </div>
  </input>
  <expectations>
    <node x="0" y="0" width="70" height="30">
      <node x="0" y="0" width="70" height="30">
        <node x="10" y="0" width="50" height="30"/>
      </node>
    </node>
  </expectations>
</test>
